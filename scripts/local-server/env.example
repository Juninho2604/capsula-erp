# ============================================================================
# Template de .env para el SERVIDOR LOCAL del restaurante.
# install-local-server.sh reemplaza los placeholders __X__ automáticamente.
# Runbook: docs/LOCAL_SERVER.md
# ============================================================================

# BD local (postgres en la misma máquina)
DATABASE_URL="postgresql://__DB_USER__:__DB_PASS__@localhost:__DB_PORT__/__DB_NAME__"

# 🔑 Para que las sesiones sean intercambiables con el VPS en un failover,
# copiar el MISMO valor que /var/www/capsula-erp/.env del VPS.
# Si se deja el generado, igual funciona (los usuarios re-loguean).
JWT_SECRET="__JWT_SECRET__"

# ── Específico del servidor local (NO copiar al VPS) ────────────────────────

# Las tablets entran por http:// plano dentro de la LAN. Una cookie `secure`
# jamás se guarda sobre http → sin esto el login queda roto en la LAN.
COOKIE_SECURE=false

# IP fija de esta máquina en la LAN (y hostname local si se configuró uno).
# CSV sin puerto. El middleware la usa para construir redirects correctos.
# ⚠️ EDITAR con la IP real, ej: EXTRA_TRUSTED_HOSTS="192.168.1.10"
EXTRA_TRUSTED_HOSTS=""

# ── Igual que el VPS ────────────────────────────────────────────────────────

# API key del print-agent (copiar del VPS para no reconfigurar el agent).
PRINT_AGENT_API_KEY=""

# Single-tenant: el fallback Shanklish aplica igual que en el VPS.
# MULTI_TENANT_STRICT=false
