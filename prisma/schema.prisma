// ============================================================================
// CONFIGURACIÓN DEL SISTEMA (clave-valor persistente)
// ============================================================================
// Usada para guardar config de instalación sin depender de variables de entorno.
// Clave: 'enabled_modules' → valor: JSON array de ids de módulos activos.

model SystemConfig {
  id        String   @id @default(cuid()) // PK cuid — desde Lote multitenant para soportar misma `key` entre tenants
  key       String // 'enabled_modules', 'business_name', etc.
  value     String // JSON string o texto plano
  updatedAt DateTime @updatedAt
  updatedBy String? // userId quien lo cambió

  // Multi-tenant: `(tenantId, key)` es compound unique → cada tenant puede
  // tener su propia config con las mismas keys.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

// Contador global de correlativo por canal (nunca se resetea)
model InvoiceCounter {
  id        String   @id @default(cuid())
  channel   String
  // "DELIVERY" | "PICKUP" | "RESTAURANT" | "PEDIDOS_YA" | "OPEN_TAB" | "GAME_SESSION"
  lastValue Int      @default(100)
  updatedAt DateTime @updatedAt

  // Multi-tenant (Fase 1.D-γ).
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, channel])
  @@index([tenantId])
}

model ExchangeRate {
  id            String   @id @default(cuid())
  rate          Float // Bs por 1 USD
  effectiveDate DateTime
  source        String   @default("BCV")
  createdAt     DateTime @default(now())

  salesOrders SalesOrder[]

  // Multi-tenant (Fase 1.D-α). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([effectiveDate])
  @@index([tenantId])
}

