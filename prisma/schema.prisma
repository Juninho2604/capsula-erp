// ============================================================================
// PROMOCIONES (happy hour por horario)
// ============================================================================
//
// Descuento automático (% o monto fijo) sobre ciertas categorías/items en
// días y horas específicas. Lo aplica el POS al armar el carrito y lo
// re-valida el servidor al crear la venta (solo toca items con promo activa;
// el resto del pricing queda intacto). Gateado por el flag tenant
// `promotionsEnabled` — sin el flag, ninguna promo se aplica.
//
// Reglas de alcance (scope):
//   - applicableCategoryIds + applicableItemIds son JSON arrays de ids.
//   - Si ambos están vacíos/null → la promo aplica a TODO el menú.
//   - Si hay categorías → aplica a items de esas categorías.
//   - Si hay items → aplica a esos items (unión con categorías).
//
// Reglas de tiempo (timezone Caracas):
//   - daysOfWeek: JSON array de números 0-6 (0=domingo). Vacío/null = todos.
//   - startTime/endTime: "HH:MM" 24h. Null = todo el día. Soporta cruce de
//     medianoche (ej. 22:00–02:00).
//   - startDate/endDate: rango de fechas opcional. Null = sin límite.
model Promotion {
  id          String  @id @default(cuid())
  name        String // Ej: "Happy Hour Cervezas"
  description String?

  // Descuento
  discountType       String // 'PERCENT' (discountValue = % 0-100) | 'FIXED' (discountValue = USD por unidad)
  discountValue      Float
  maxDiscountPerUnit Float? // tope opcional de descuento por unidad (solo PERCENT)

  // Alcance (JSON arrays de ids; vacío = todo el menú)
  applicableCategoryIds String? @default("[]")
  applicableItemIds     String? @default("[]")

  // Ventana de tiempo (Caracas)
  daysOfWeek String?   @default("[]") // JSON array de 0-6 (0=domingo)
  startTime  String? // "HH:MM" 24h, null = todo el día
  endTime    String? // "HH:MM" 24h
  startDate  DateTime? // rango de fechas opcional
  endDate    DateTime?

  // Si dos promos aplican al mismo item, gana la de mayor priority (no se
  // acumulan, para evitar descuentos descontrolados). Empate → mayor descuento.
  priority Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete
  deletedAt DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
  @@index([isActive])
}

// §86 — Listas de precios por canal. Un gerente crea listas, les asigna
// canales (delivery/wink/restaurante/pedidosya) y las activa/desactiva. La
// lista ACTIVA de mayor priority que cubre un canal define el precio de sus
// items en ese canal; los items sin override caen al price base del MenuItem.
model PriceList {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Canales que cubre (JSON array de keys: "RESTAURANT","DELIVERY","WINK",
  // "PEDIDOSYA","PICKUP"). Vacío = no aplica a ningún canal (inerte).
  channels String @default("[]")

  // Si dos listas activas cubren el mismo canal, gana mayor priority; empate
  // → la de updatedAt más reciente.
  priority Int     @default(0)
  isActive Boolean @default(true)

  items PriceListItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
  @@index([isActive])
}

model PriceListItem {
  id          String    @id @default(cuid())
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  menuItemId String
  menuItem   MenuItem @relation("MenuItemPriceListItems", fields: [menuItemId], references: [id], onDelete: Cascade)

  price Float // USD para este item en esta lista

  @@unique([priceListId, menuItemId])
  @@index([menuItemId])
}

model MenuModifierGroup {
  id          String  @id @default(cuid())
  name        String // Ej: "AcompaÃ±antes", "TamaÃ±o", "Extras"
  description String?

  // Reglas de selecciÃ³n
  isRequired    Boolean @default(false) // Debe seleccionar al menos uno
  minSelections Int     @default(0)
  maxSelections Int     @default(99) // 99 = sin lÃ­mite

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  // Relaciones
  modifiers MenuModifier[]
  menuItems MenuItemModifierGroup[]

  // Modificadores (de otros grupos) que despliegan ESTE grupo como
  // sub-selección al ser elegidos en el POS (§82 — anidación de 1 nivel).
  parentModifiers MenuModifier[] @relation("ModifierChildGroup")

  createdAt DateTime @default(now())

  // Multi-tenant (Fase 1.D-α). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
}

model MenuModifier {
  id      String            @id @default(cuid())
  groupId String
  group   MenuModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  name            String // Ej: "TabulÃ©", "Vegetales Salteados"
  priceAdjustment Float  @default(0) // +$0.50, -$1.00, etc.

  isAvailable Boolean @default(true)
  sortOrder   Int     @default(0)

  // Vínculo a MenuItem para descargo de inventario por modificador
  // Cuando el cliente elige este modificador, se descarga la receta del plato vinculado
  linkedMenuItemId String?
  linkedMenuItem   MenuItem? @relation("ModifierLinkedItem", fields: [linkedMenuItemId], references: [id])

  // Sub-grupo anidado (§82): al seleccionar este modificador en el POS se
  // despliega childGroup para una segunda selección (ej. "Pincho Mixto" →
  // elegir sabores de las varas). UN solo nivel de anidación; los hijos
  // viajan como modifiers normales en el carrito (precio/inventario/cocina
  // funcionan sin cambios).
  childGroupId String?
  childGroup   MenuModifierGroup? @relation("ModifierChildGroup", fields: [childGroupId], references: [id])

  // Relaciones
  orderItemModifiers SalesOrderItemModifier[]

  // Receta PROPIA del modificador (§80): ingredientes directos de inventario.
  // Si tiene filas acá, el descargo usa ESTO y se ignora linkedMenuItemId.
  // Evita crear MenuItems placeholder por cada variante (ej. tipos de leche,
  // "cambiar lomito por kafta" → X gramos de KAFTA KG directo).
  ingredients MenuModifierIngredient[]

  // Soft Delete
  deletedAt DateTime?

  // Multi-tenant (Fase 1.D-α). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([groupId])
  @@index([linkedMenuItemId])
  @@index([childGroupId])
  @@index([deletedAt])
  @@index([tenantId])
}

/// Ingrediente directo de un modificador (§80). Sin tenantId: hereda scope
/// vía el modifier (patrón RecipeIngredient/WeeklyCountItem). Cantidad en la
/// unidad indicada por porción del plato al que se aplica el modificador.
model MenuModifierIngredient {
  id         String       @id @default(cuid())
  modifierId String
  modifier   MenuModifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)

  ingredientItemId String
  ingredientItem   InventoryItem @relation("ModifierIngredientItem", fields: [ingredientItemId], references: [id])

  quantity Float
  unit     String // KG, G, L, ML, UNIT — informativo; el stock se mueve en esta cantidad

  @@unique([modifierId, ingredientItemId])
  @@index([ingredientItemId])
}

// Tabla pivote: QuÃ© grupos de modificadores aplican a quÃ© productos
model MenuItemModifierGroup {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  modifierGroupId String
  modifierGroup   MenuModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, modifierGroupId])
}

