model SalesOrder {
  id String @id @default(cuid())

  // Correlativo único por día (Ej: "REST-2026-01-27-001") — unique compuesto con tenantId abajo
  orderNumber String

  // Tipo de venta
  orderType     String @default("RESTAURANT") // RESTAURANT, DELIVERY
  serviceFlow   String @default("DIRECT_SALE") // DIRECT_SALE, OPEN_TAB, TAB_CLOSING
  sourceChannel String @default("POS_RESTAURANT")

  // Número de orden del día por canal (§84). Correlativo corto que resetea
  // cada día — ej. DL-14 (delivery 14 del día), MS-23 (mesa/restaurante).
  // Se imprime junto al orderNumber global. Pickup mantiene su propio PK
  // (sistema aparte). null en órdenes viejas / canales sin numeración diaria.
  dailyNumber Int?
  dailyLabel  String?

  // Cliente (opcional)
  customerName    String?
  customerPhone   String?
  customerAddress String? // Para delivery

  // Vínculo a la ficha de cliente (CRM). Nullable: ventas anónimas (mesa sin
  // cliente) o históricas quedan sin vincular. Se setea de ahora en adelante.
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Estado
  status        String @default("PENDING") // PENDING, CONFIRMED, PREPARING, READY, DELIVERED, CANCELLED
  kitchenStatus String @default("NOT_SENT") // NOT_SENT, SENT, IN_PROGRESS, READY, NOT_REQUIRED

  // Totales
  subtotal Float @default(0)
  discount Float @default(0)
  tax      Float @default(0)
  total    Float @default(0)

  // Detalles de Descuento
  discountType   String? // DIVISAS_33, CORTESIA_100, etc.
  discountReason String?
  authorizedById String?
  authorizedBy   User?   @relation("SalesOrderAuthorizer", fields: [authorizedById], references: [id])

  // Anulación
  voidedAt   DateTime?
  voidedById String?
  voidedBy   User?     @relation("SalesOrderVoider", fields: [voidedById], references: [id])
  voidReason String?

  // MÃ©todo de pago

  // MÃ©todo de pago
  paymentMethod String? // CASH, CARD, TRANSFER, MULTIPLE
  paymentStatus String  @default("PENDING") // PENDING, PAID, PARTIAL, REFUNDED
  amountPaid    Float   @default(0)
  change        Float   @default(0) // Vuelto

  // AuditorÃ­a
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sentToKitchenAt DateTime?
  // Cuándo la cocina marcó la orden como lista (Reportes FASE B — tiempos
  // de cocina). Lo setea el PATCH de /api/kitchen/orders al pasar a READY.
  kitchenReadyAt  DateTime?
  closedAt        DateTime?

  // Hora de entrega solicitada (PICKUP/DELIVERY). Si la cajera la captura,
  // la cocina la ve en la comanda y prioriza vs los "ASAP". Null = lo antes
  // posible.
  scheduledDeliveryTime DateTime?

  // Cajera que creÃ³ la orden
  createdById String
  createdBy   User   @relation("SalesOrderCreator", fields: [createdById], references: [id])

  // Ã�rea de la que se descuenta inventario
  areaId           String
  area             Area            @relation(fields: [areaId], references: [id])
  branchId         String?
  branch           Branch?         @relation(fields: [branchId], references: [id])
  serviceZoneId    String?
  serviceZone      ServiceZone?    @relation(fields: [serviceZoneId], references: [id])
  tableOrStationId String?
  tableOrStation   TableOrStation? @relation(fields: [tableOrStationId], references: [id])
  openTabId        String?
  openTab          OpenTab?        @relation(fields: [openTabId], references: [id])

  // Mesonero (del Waiter model, identificado por PIN en POS Mesero)
  waiterProfileId String?
  waiterProfile   Waiter? @relation(fields: [waiterProfileId], references: [id])

  // Snapshot financiero
  exchangeRateId    String?
  exchangeRate      ExchangeRate? @relation(fields: [exchangeRateId], references: [id])
  exchangeRateValue Float?
  totalBs           Float?

  // Turno de caja en el que se cobró (Reportes FASE B — habilita Reporte X
  // por turno/cajero). Nullable: órdenes históricas y ventas sin caja abierta.
  cashRegisterId String?
  cashRegister   CashRegister? @relation("CashRegisterOrders", fields: [cashRegisterId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Notas
  notes String?

  // LÃ­neas de la orden
  items SalesOrderItem[]

  // Movimientos de inventario generados
  inventoryMovements InventoryMovement[]       @relation("SaleMovements")
  openTabLinks       OpenTabOrder[]
  paymentSplits      PaymentSplit[]
  orderPayments      SalesOrderPayment[]
  gameSessions       GameSession[]             @relation("GameSessions")
  // Outbox de descargo de inventario (Fase 2 — propuesta 001)
  deductionRetries   InventoryDeductionRetry[]

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, orderNumber])
  @@index([orderNumber])
  @@index([orderType])
  @@index([status])
  @@index([createdAt])
  @@index([createdById])
  @@index([serviceFlow])
  @@index([kitchenStatus])
  @@index([branchId])
  @@index([serviceZoneId])
  @@index([tableOrStationId])
  @@index([openTabId])
  @@index([tenantId])
  @@index([customerId])
  @@index([cashRegisterId])
  @@index([tenantId, createdAt])
  @@index([tenantId, voidedAt])
}

model SalesOrderItem {
  id String @id @default(cuid())

  orderId String
  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  // Snapshot del nombre y precio al momento de la venta
  itemName  String // Nombre del producto al momento de la venta
  unitPrice Float
  quantity  Int    @default(1)

  // Subtotal de esta lÃ­nea (unitPrice * quantity + modificadores)
  lineTotal Float

  // ── Promoción aplicada (happy hour por horario) ──────────────────────────
  // Snapshot — NO hay FK a Promotion para que borrar/editar una promo no
  // afecte ventas históricas. unitPrice ya viene con el descuento aplicado;
  // estos campos son solo para auditoría y reporte. Null = sin promo.
  appliedPromotionId   String? // id de la Promotion vigente al cobrar
  appliedPromotionName String? // nombre snapshot para mostrar sin join
  originalUnitPrice    Float? // precio de lista antes de la promo
  promotionDiscount    Float? // descuento total de la línea por la promo (≥0)

  // Notas especiales (Ej: "Sin cebolla")
  notes String?

  // Snapshot de costo (margen retroactivo)
  costPerUnit   Float?
  costTotal     Float?
  marginPerUnit Float?
  marginPercent Float?

  // Soft delete / void tracking
  voidedAt         DateTime?
  voidReason       String?
  voidedByWaiterId String?
  voidedByWaiter   Waiter?          @relation("ItemVoidedByWaiter", fields: [voidedByWaiterId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  voidedByUserId   String?
  voidedByUser     User?            @relation("ItemVoidedByUser", fields: [voidedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  replacedByItemId String?
  replacedByItem   SalesOrderItem?  @relation("ItemReplacement", fields: [replacedByItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  replacements     SalesOrderItem[] @relation("ItemReplacement")

  // Modificadores seleccionados
  modifiers       SalesOrderItemModifier[]
  // Asignaciones a subcuentas
  subAccountItems SubAccountItem[]

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId])
  @@index([menuItemId])
  @@index([voidedAt])
  @@index([voidedByWaiterId])
  @@index([voidedByUserId])
  @@index([tenantId])
}

model SalesOrderItemModifier {
  id String @id @default(cuid())

  orderItemId String
  orderItem   SalesOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  modifierId String?
  modifier   MenuModifier? @relation(fields: [modifierId], references: [id])

  // Snapshot del nombre y ajuste de precio al momento de la venta
  name            String // Nombre del modificador
  priceAdjustment Float  @default(0)

  // SIN estilo Xetux (§94): si está seteado, esta fila es una EXCLUSIÓN
  // ("SIN Salsa de Ajo"): el InventoryItem referenciado NO se descarga de la
  // receta principal del item. modifierId queda null (no hay MenuModifier).
  excludedIngredientItemId String?

  // §95: renglón interno — modificador PADRE de un sub-grupo anidado (ej. la
  // ración "Pincho Mixto"). No se imprime NI en comanda NI en recibo; solo
  // las varas/hijos. Precio e inventario no cambian. Persistido desde el
  // carrito para que reimpresiones y recibos desde BD filtren directo.
  hideFromKitchen Boolean @default(false)

  @@index([orderItemId])
}

// ============================================================================
// INVENTARIO DIARIO
// ============================================================================

model DailyInventory {
  id     String   @id @default(cuid())
  date   DateTime // @db.Date no soportado en SQLite/algunas confs, usar DateTime normal y truncar
  areaId String
  area   Area     @relation(fields: [areaId], references: [id])

  status String @default("DRAFT") // DRAFT, OPEN, CLOSED

  openedAt   DateTime?
  closedAt   DateTime?
  closedById String?
  closedBy   User?     @relation(fields: [closedById], references: [id])

  totalVarianceValue Float?

  items DailyInventoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([date, areaId])
  @@index([tenantId])
}

model DailyInventoryItem {
  id               String         @id @default(cuid())
  dailyInventoryId String
  dailyInventory   DailyInventory @relation(fields: [dailyInventoryId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  initialCount            Float? @default(0)
  // Apertura teórica: cierre del día anterior (auto-arrastrado, read-only).
  // initialCount es el conteo físico real de la mañana (editable).
  theoreticalInitialCount Float? @default(0)
  finalCount              Float? @default(0)

  // Movimientos calculados
  entries Float @default(0)
  sales   Float @default(0)
  waste   Float @default(0)

  theoreticalStock Float?
  variance         Float?

  unit        String
  costPerUnit Float?

  notes String?

  @@unique([dailyInventoryId, inventoryItemId])
}

// ============================================================================
// PRESTAMOS (LOANS)
// ============================================================================

model InventoryLoan {
  id String @id @default(cuid())

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  loaneeName String // Nombre del restaurante/persona
  quantity   Float
  unit       String

  type   String // REPLACEMENT, PAYMENT
  status String @default("PENDING") // PENDING, COMPLETED, CANCELLED

  agreedPrice Float? // Precio unitario acordado (si es venta/pago)

  loanDate   DateTime  @default(now())
  resolvedAt DateTime?
  notes      String?

  createdById String
  createdBy   User   @relation("LoanCreator", fields: [createdById], references: [id])

  // Movimientos asociados
  movements InventoryMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([status])
  @@index([loaneeName])
  @@index([createdById])
  @@index([tenantId])
}

// ============================================================================
// AUDITORÍAS DE INVENTARIO
// ============================================================================

model InventoryAudit {
  id String @id @default(cuid())

  // Estado de la auditoría
  status String @default("DRAFT") // DRAFT, APPROVED, REJECTED

  // Metadatos
  name   String? // Ej: "Inventario Mensual Enero"
  notes  String?
  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id])

  // Fecha efectiva: permite cargar auditorías retroactivas (ej: inventario del domingo cargado el lunes)
  effectiveDate DateTime? // Si no se especifica, se usa createdAt

  // Auditoría del registro
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("AuditCreator", fields: [createdById], references: [id])

  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("AuditResolver", fields: [resolvedById], references: [id])

  // Relaciones
  items InventoryAuditItem[]

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([status])
  @@index([createdAt])
  @@index([createdById])
  @@index([tenantId])
}

model InventoryAuditItem {
  id      String         @id @default(cuid())
  auditId String
  audit   InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  // Valores
  systemStock  Float // Stock que decía el sistema al momento de crear la auditoría
  countedStock Float // Stock real contado
  difference   Float // Calculado: counted - system

  costSnapshot Float? // Costo unitario en ese momento

  notes String?

  @@index([auditId])
  @@index([inventoryItemId])
}

// ============================================================================
// PROVEEDORES Y ÓRDENES DE COMPRA
// ============================================================================

model Supplier {
  id          String  @id @default(cuid())
  name        String
  code        String? // Código interno del proveedor — unique compuesto con tenantId abajo
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?

  rif         String? // §115: RIF fiscal — necesario para retenciones IVA/ISLR

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.B). Opcional por ahora; backfill en 1.C, NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Relaciones
  purchaseOrders     PurchaseOrder[]
  // Productos que suministra este proveedor
  suppliedItems      SupplierItem[]
  // Procesamiento de Proteínas
  proteinProcessings ProteinProcessing[]
  // Módulo Financiero
  accountsPayable    AccountPayable[]
  // Histórico de precios (Fase 2 — propuesta 002)
  priceHistory       SupplierItemPriceHistory[]
  // §115: anticipos (abonos sin factura)
  advances           SupplierAdvance[]

  @@unique([tenantId, code])
  @@index([name])
  @@index([tenantId])
}

// Relación entre Proveedor y los Items que puede suministrar
model SupplierItem {
  id              String        @id @default(cuid())
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  // Precio de referencia del proveedor
  unitPrice    Float?
  leadTimeDays Int? // Tiempo de entrega en días
  minimumOrder Float? // Cantidad mínima de pedido

  isPreferred Boolean @default(false) // Proveedor preferido para este item

  @@unique([supplierId, inventoryItemId])
  @@index([supplierId])
  @@index([inventoryItemId])
}

model PurchaseOrder {
  id          String  @id @default(cuid())
  orderNumber String // Ej: OC-2026-0001 — unique compuesto con tenantId abajo
  orderName   String? // Nombre descriptivo: VEGETALES, COCHE, etc.

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  status String @default("DRAFT") // DRAFT, SENT, PARTIAL, RECEIVED, CANCELLED

  // Fechas
  orderDate    DateTime  @default(now())
  expectedDate DateTime? // Fecha esperada de recepción
  receivedDate DateTime?

  // Totales
  subtotal    Float @default(0)
  taxAmount   Float @default(0)
  totalAmount Float @default(0)

  notes         String?
  internalNotes String? // Notas internas no visibles en la orden impresa

  // Auditoría
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("PurchaseOrderCreator", fields: [createdById], references: [id])

  receivedById String?
  receivedBy   User?   @relation("PurchaseOrderReceiver", fields: [receivedById], references: [id])

  // Items de la orden
  items                 PurchaseOrderItem[]
  accountsPayable       AccountPayable[]
  // Fase 2 — propuesta 002: cambios de precio que dispararon esta OC
  triggeredPriceChanges SupplierItemPriceHistory[]

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, orderNumber])
  @@index([status])
  @@index([orderDate])
  @@index([supplierId])
  @@index([tenantId])
  @@index([tenantId, orderDate])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  // Cantidades
  quantityOrdered  Float // Cantidad solicitada
  quantityReceived Float  @default(0) // Cantidad recibida
  unit             String

  // Precios
  unitPrice  Float @default(0)
  totalPrice Float @default(0)

  // Información adicional
  notes String?

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

// ============================================================================
// DOCUMENTOS DE PROVEEDOR — facturas / notas de entrega (Compras Fase A)
// ============================================================================
// El "papel" del proveedor como entidad de primera clase, DECOPLADO del
// inventario y de la orden de compra: se puede crear solo, darle entrada al
// inventario, vincularlo a una OC y/o generar la deuda — en cualquier orden.
// supplierId/linkedPurchaseOrderId/accountPayableId/createdById son scalars
// (sin FK) para no acoplar Supplier/PurchaseOrder/AccountPayable/User.

model SupplierDocument {
  id             String  @id @default(cuid())
  documentType   String // FACTURA | NOTA_ENTREGA
  documentNumber String
  supplierId     String? // scalar (proveedor del sistema, opcional)
  supplierName   String? // texto libre si no está en el sistema

  documentDate     DateTime
  paymentCondition String   @default("CONTADO") // CONTADO | CREDITO
  totalAmount      Float    @default(0)
  currency         String   @default("USD")
  documentUrl      String? // foto/PDF del documento

  // Estado de vínculos (cada uno independiente)
  inventoryStatus       String    @default("NOT_ENTERED") // NOT_ENTERED | ENTERED
  inventoryEnteredAt    DateTime?
  linkedPurchaseOrderId String? // scalar — OC vinculada (caso: entró por OC antes)
  accountPayableId      String? // scalar — deuda generada (si crédito)

  status String  @default("ACTIVE") // ACTIVE | VOID
  notes  String?

  createdById String // scalar (sin FK)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items SupplierDocumentItem[]

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
  @@index([documentType])
  @@index([inventoryStatus])
  @@index([linkedPurchaseOrderId])
  @@index([status])
}

/// Línea de un documento de proveedor. Sin tenantId: hereda vía el documento.
model SupplierDocumentItem {
  id                 String           @id @default(cuid())
  supplierDocumentId String
  supplierDocument   SupplierDocument @relation(fields: [supplierDocumentId], references: [id], onDelete: Cascade)

  inventoryItemId String // scalar (se valida en la action)
  itemName        String // snapshot del nombre
  quantity        Float
  unit            String
  unitCost        Float  @default(0)
  lineTotal       Float  @default(0)

  @@index([supplierDocumentId])
}

// ============================================================================
// AUDIT LOG - REGISTRO FORENSE DE OPERACIONES
// ============================================================================
// Esta tabla NUNCA se borra. Solo se puede archivar a cold storage.
// Toda server action que modifique datos debe crear un AuditLog.
// ============================================================================

model AuditLog {
  id String @id @default(cuid())

  // QUIÉN
  userId   String
  userName String // Snapshot para no depender de JOIN
  userRole String // Rol al momento de la acción

  // QUÉ
  action     String // CREATE, UPDATE, DELETE, VOID, APPROVE, REJECT, LOGIN, LOGOUT
  entityType String // SalesOrder, InventoryMovement, Recipe, etc.
  entityId   String // ID del registro afectado

  // DETALLE
  description String? // Descripción legible: "Creó orden REST-2026-03-15-001"
  changes     String? // JSON: { field: { from: "X", to: "Y" } }
  metadata    String? // JSON: datos contextuales adicionales

  // DESDE DÓNDE
  ipAddress String?
  userAgent String?
  deviceId  String? // Identificador de terminal/caja

  // CUÁNDO
  createdAt DateTime @default(now())

  // CONTEXTO OPERATIVO
  module String? // POS, INVENTORY, PRODUCTION, RECIPE, etc.

  // Multi-tenant (Fase 1.D-α). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([module])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}

// ============================================================================
// MÓDULO FINANCIERO - GASTOS, CAJA Y CUENTAS POR PAGAR
// ============================================================================

/// Categorías de gastos operativos (alquiler, servicios, nómina, etc.)
model ExpenseCategory {
  id          String  @id @default(cuid())
  name        String // ej: "Alquiler", "Servicios Públicos", "Nómina" — unique compuesto con tenantId abajo
  description String?
  color       String? // hex color para UI, ej: "#3B82F6"
  icon        String? // emoji, ej: "🏠"
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant (Fase 1.B). Opcional por ahora; backfill en 1.C, NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  expenses Expense[]

  @@unique([tenantId, name])
  @@index([isActive])
  @@index([tenantId])
}

/// Registro de gastos operativos (no de compras de inventario)
model Expense {
  id String @id @default(cuid())

  // Descripción
  description String // Ej: "Pago alquiler local enero 2026"
  notes       String? // Notas adicionales o referencia

  // Clasificación
  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])

  // Monto
  amountUsd    Float // Monto en USD (moneda base del sistema)
  amountBs     Float? // Monto en Bs (opcional, para referencia)
  exchangeRate Float? // Tasa usada para conversión

  // Pago
  paymentMethod String // CASH_USD, CASH_BS, ZELLE, BANK_TRANSFER, MOBILE_PAY, CHECK, OTHER
  paymentRef    String? // Referencia de pago (número de transacción, cheque, etc.)
  paidAt        DateTime // Fecha del pago/gasto

  // Estado
  status     String    @default("CONFIRMED") // CONFIRMED, VOID
  voidReason String?
  voidedAt   DateTime?
  voidedById String?

  // Comprobante
  receiptUrl String? // URL de imagen/PDF del comprobante (opcional)

  // Período al que pertenece
  periodMonth Int // 1-12
  periodYear  Int

  // Auditoría
  createdById String
  createdBy   User     @relation("ExpenseCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Tesorería (Fase 0): cuenta bancaria desde la que SALIÓ el gasto. Nullable.
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([categoryId])
  @@index([paidAt])
  @@index([periodYear, periodMonth])
  @@index([status])
  @@index([createdById])
  @@index([tenantId])
  @@index([bankAccountId])
  @@index([tenantId, paidAt])
}

/// Apertura y cierre de caja (para cuadre de efectivo al inicio/fin del turno)
model CashRegister {
  id String @id @default(cuid())

  // Identificador de caja/terminal
  registerName String // ej: "Caja Restaurante", "Caja Delivery"
  shiftDate    DateTime // Fecha del turno (solo fecha, sin hora)
  shiftType    String   @default("DAY") // DAY, NIGHT, MORNING

  // Estado
  status String @default("OPEN") // OPEN, CLOSED

  // Apertura
  openingCashUsd Float    @default(0) // Fondo inicial en USD
  openingCashBs  Float    @default(0) // Fondo inicial en Bs
  openedAt       DateTime @default(now())
  openedById     String
  openedBy       User     @relation("CashRegisterOpener", fields: [openedById], references: [id])

  // Cierre
  closingCashUsd Float? // Efectivo contado al cierre en USD
  closingCashBs  Float? // Efectivo contado al cierre en Bs
  closedAt       DateTime?
  closedById     String?
  closedBy       User?     @relation("CashRegisterCloser", fields: [closedById], references: [id])

  // Resumen calculado al cierre
  totalSalesUsd Float? // Total ventas del turno
  totalExpenses Float? // Total gastos del turno
  expectedCash  Float? // Efectivo esperado (apertura + ventas efectivo - gastos)
  difference    Float? // Diferencia (cierre contado - esperado)

  // Desglose de billetes (JSON nullable — no rompe registros existentes)
  // Formato: {"100":6,"50":2,"20":29,"10":10,"5":6,"1":21,"total":1431.00}
  openingDenominationsJson String?
  closingDenominationsJson String?

  // Operadoras activas en este turno (JSON array de nombres, nullable)
  // Ejemplo: ["Ana García", "María López"]
  operatorsJson String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Órdenes cobradas durante este turno (Reportes FASE B — Reporte X)
  salesOrders SalesOrder[] @relation("CashRegisterOrders")

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([shiftDate])
  @@index([status])
  @@index([openedById])
  @@index([tenantId])
  @@index([tenantId, shiftDate])
}

/// Cuentas por pagar — facturas/deudas pendientes con proveedores u otros acreedores
model AccountPayable {
  id String @id @default(cuid())

  // Descripción
  description   String // Ej: "Factura vegetales 15/03/2026"
  invoiceNumber String? // Número de factura del proveedor
  invoiceUrl    String? // URL del comprobante

  // Acreedor
  supplierId   String? // Si es un proveedor del sistema
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  creditorName String? // Si no está en el sistema de proveedores

  // Montos
  totalAmountUsd Float // Monto total de la deuda en USD
  paidAmountUsd  Float @default(0) // Monto pagado acumulado (efectivo + anticipos aplicados)
  remainingUsd   Float // Saldo pendiente (total - paid - retenciones)
  // §115: retenciones que cierran saldo SIN salida de efectivo al proveedor.
  retentionIvaUsd  Float @default(0)
  retentionIslrUsd Float @default(0)

  // Fechas
  invoiceDate DateTime // Fecha de la factura
  dueDate     DateTime? // Fecha de vencimiento (opcional)
  fullyPaidAt DateTime? // Fecha en que quedó saldada

  // Estado
  status String @default("PENDING") // PENDING, PARTIAL, PAID, OVERDUE, DISPUTED, VOID

  // Relación con PurchaseOrder (si aplica)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  // Auditoría
  createdById String
  createdBy   User     @relation("AccountPayableCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments AccountPayment[]

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([status])
  @@index([dueDate])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([createdById])
  @@index([tenantId])
}

/// Pagos individuales aplicados a una cuenta por pagar
model AccountPayment {
  id               String         @id @default(cuid())
  accountPayableId String
  accountPayable   AccountPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)

  amountUsd     Float
  amountBs      Float?
  exchangeRate  Float?
  paymentMethod String // CASH_USD, CASH_BS, ZELLE, BANK_TRANSFER, MOBILE_PAY, CHECK
  paymentRef    String? // Referencia de transferencia, cheque, etc.
  paidAt        DateTime

  notes String?

  // §115: false = aplicación de un anticipo (el efectivo ya salió antes) →
  // NO cuenta como egreso de caja. true = pago en efectivo real.
  isCash           Boolean @default(true)
  // §115: si vino de aplicar un anticipo, cuál.
  supplierAdvanceId String?
  supplierAdvance   SupplierAdvance? @relation(fields: [supplierAdvanceId], references: [id])

  createdById String
  createdBy   User     @relation("AccountPaymentCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  // Tesorería (Fase 0): cuenta bancaria desde la que SALIÓ el pago. Nullable.
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([accountPayableId])
  @@index([paidAt])
  @@index([tenantId])
  @@index([bankAccountId])
}

// ============================================================================
// CUENTAS POR COBRAR — "nos deben" (Fase 4)
// ============================================================================
// Espejo de AccountPayable: dinero que terceros le deben al negocio (el
// "CRÉDITO NOS DEBEN" del Excel). createdById/customerId/bankAccountId son
// scalars sin FK (como reconciledById) para no acoplar User/Customer.

/// Cuenta por cobrar — deuda a favor del negocio.
model AccountReceivable {
  id          String  @id @default(cuid())
  description String
  reference   String? // # de nota/recibo
  debtorName  String // quién nos debe (cliente, tercero)
  customerId  String? // opcional: ficha de cliente (CRM), sin FK

  totalAmountUsd     Float
  collectedAmountUsd Float @default(0)
  remainingUsd       Float

  issueDate        DateTime
  dueDate          DateTime?
  fullyCollectedAt DateTime?

  status String  @default("PENDING") // PENDING, PARTIAL, COLLECTED, OVERDUE, VOID
  notes  String?

  createdById String // sin FK (scalar)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments ReceivablePayment[]

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([status])
  @@index([dueDate])
  @@index([tenantId])
}

/// Cobro individual aplicado a una cuenta por cobrar.
model ReceivablePayment {
  id                  String            @id @default(cuid())
  accountReceivableId String
  accountReceivable   AccountReceivable @relation(fields: [accountReceivableId], references: [id], onDelete: Cascade)

  amountUsd     Float
  amountBs      Float?
  exchangeRate  Float?
  method        String // cómo nos pagaron
  reference     String?
  bankAccountId String? // cuenta que recibió el cobro (scalar, sin FK)
  collectedAt   DateTime
  notes         String?

  createdById String // sin FK (scalar)
  createdAt   DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([accountReceivableId])
  @@index([collectedAt])
  @@index([tenantId])
}

// ============================================================================
// TESORERÍA / CONCILIACIÓN BANCARIA (Fase 0)
// ============================================================================
// La cuenta bancaria es el eje de la conciliación: por cada cuenta ENTRA la
// venta liquidada por PDV/PM y SALE el gasto/pago. El saldo esperado
// (entradas − salidas, derivado de las tablas existentes) se compara contra
// el estado de cuenta. Ver docs/PLAN_TESORERIA_CONCILIACION.md.

/// Cuenta bancaria / caja del negocio (NOUR, SUPERFERRO, BOFA, CASH…).
model BankAccount {
  id       String  @id @default(cuid())
  name     String // "PROVINCIAL NOUR", "SUPERFERRO", "BOFA", "CASH BS"…
  bankName String? // "Banco Provincial", "Bank of America"
  // Moneda nativa de la cuenta. Decide si aplica conversión Bs→$ y pérdida BCV.
  currency String  @default("BS") // BS | USD
  // Naturaleza: cuenta bancaria, caja de efectivo, o billetera digital (Zelle).
  kind     String  @default("BANK") // BANK | CASH | DIGITAL
  rif      String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  notes     String?

  // ── Comisiones configurables (pago móvil / transferencia de la cuenta) ──────
  // Por dirección (ingreso/egreso) y tipo de contraparte (persona natural /
  // jurídica). Regla típica VE: ingreso natural = 0; jurídica cobra; egreso
  // cobra a ambas. Todo configurable. Los PDV tienen sus propias tasas en
  // PosTerminal. Valores en % (ej. 0.3 = 0.3%).
  commInNaturalPct   Float @default(0) // ingreso, persona natural
  commInJuridicaPct  Float @default(0) // ingreso, persona jurídica
  commOutNaturalPct  Float @default(0) // egreso, persona natural
  commOutJuridicaPct Float @default(0) // egreso, persona jurídica

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  terminals          PosTerminal[]
  salesOrderPayments SalesOrderPayment[]
  expenses           Expense[]
  accountPayments    AccountPayment[]
  reconciliations    BankReconciliation[]
  exchangesFrom        CurrencyExchange[]            @relation("CurrencyExchangeFrom")
  exchangeDestinations CurrencyExchangeDestination[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isActive])
}

/// Terminal de punto de venta (PDV). Abona a una cuenta y cobra una comisión.
model PosTerminal {
  id              String  @id @default(cuid())
  label           String // "PDV Superferro", "PDV Shanklish"
  terminalCode    String? // número de afiliación / serial del POS
  // Mapea al método de pago del POS para atribuir ventas automáticamente.
  // Ej: "PDV_SUPERFERRO", "PDV_SHANKLISH", "MOVIL_NG".
  posMethodKey    String?
  // Comisión por defecto (legado — se usa como fallback de la tasa natural).
  commissionPct   Float   @default(0)
  // Comisiones configurables del PDV por tipo de contraparte (% sobre la venta).
  commNaturalPct  Float   @default(0) // persona natural
  commJuridicaPct Float   @default(0) // persona jurídica

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, label])
  @@index([tenantId])
  @@index([bankAccountId])
  @@index([posMethodKey])
}

/// Conciliación bancaria por cuenta y día (Fase 2).
/// El lado "esperado" (entradas del POS + comisión) se deriva y se CONGELA al
/// guardar; el "estado de cuenta" lo teclea el usuario. El diferencial revela
/// si la comisión real coincide con la calculada. Montos en la moneda de la
/// cuenta (Bs o $). Los campos BCV se llenan en Fase 3.
model BankReconciliation {
  id            String      @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  date       DateTime // día conciliado (medianoche Caracas como UTC)
  fiscalWeek String // etiqueta editable, ej "S5 ABRIL"

  // Lado sistema (derivado, congelado al guardar)
  expectedIn     Float @default(0) // ventas PDV/PM que entraron a la cuenta
  commissionCalc Float @default(0) // comisión calculada por Kpsula

  // Lado banco (tecleado)
  statementIn    Float? // monto que el estado de cuenta dice que llegó (neto)
  commissionStmt Float? // comisión según el banco (opcional)

  // Resultado
  differential Float  @default(0) // (esperado − estado) − comisión calculada
  status       String @default("OPEN") // OPEN | RECONCILED | DISCREPANCY

  // Pérdida BCV (Fase 3 — solo cuentas Bs)
  rateAtSettle Float?
  bcvLossUsd   Float?

  // Gasto auto-generado por comisión + pérdida BCV (Fase 3)
  postedExpenseId String?

  notes          String?
  reconciledById String? // id del usuario (sin FK, como otros campos del repo)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, bankAccountId, date])
  @@index([tenantId])
  @@index([bankAccountId])
  @@index([date])
  @@index([status])
}

/// Estado de conciliación POR MOVIMIENTO (Fase 3 — conciliación de verdad).
/// No duplica el dato de la venta/gasto: guarda solo el estado del movimiento
/// (conciliado, contraparte para la comisión, comisión quitada/ajustada, monto
/// del banco si difiere). Los movimientos se derivan en vivo (SalesOrderPayment,
/// Expense, AccountPayment) y se cruzan con esta tabla por (sourceType, sourceId).
model BankMovementRecon {
  id            String @id @default(cuid())
  bankAccountId String // scalar (sin FK; se filtra por él)

  sourceType String // SALE_PAYMENT | EXPENSE | ACCOUNT_PAYMENT
  sourceId   String // id del registro de origen
  date       DateTime

  // Contraparte → decide el % de comisión (natural/jurídica).
  counterpartyType String @default("NATURAL") // NATURAL | JURIDICA

  // Ajustes manuales de comisión.
  commissionRemoved     Boolean @default(false) // el usuario quitó la comisión
  commissionOverridePct Float? // % manual (null = usar config de la cuenta/terminal)

  // Conciliación contra el banco.
  reconciled      Boolean @default(false)
  statementAmount Float? // monto según el estado de cuenta (si difiere → discrepancia)
  notes           String?

  reconciledById String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, sourceType, sourceId])
  @@index([tenantId])
  @@index([bankAccountId])
  @@index([date])
}

// ============================================================================
// MODELO OPERATIVO RESTAURANTE
// ============================================================================

model Branch {
  id           String   @id @default(cuid())
  code         String
  name         String
  legalName    String?
  timezone     String   @default("America/Caracas")
  currencyCode String   @default("USD")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  areas           Area[]
  serviceZones    ServiceZone[]
  tableOrStations TableOrStation[]
  openTabs        OpenTab[]
  salesOrders     SalesOrder[]
  gameStations    GameStation[]
  waiters         Waiter[]

  // Módulo Gestión de Deliverys (módulo aislado, feature flag deliveryOps).
  deliveryConfig     BranchDeliveryConfig?
  deliveryZones      DeliveryZone[]
  deliveryOrders     DeliveryOrder[]
  deliveryDrivers    DeliveryDriver[]
  itemAvailabilities ItemAvailability[]
  managerNotes       ManagerNote[]
  routingRules       RoutingRule[]

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Waiter {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  pin       String?
  isActive  Boolean  @default(true)
  isCaptain Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  openTabs            OpenTab[]
  salesOrders         SalesOrder[]
  voidedItems         SalesOrderItem[] @relation("ItemVoidedByWaiter")
  transfersFrom       TableTransfer[]  @relation("TransferFrom")
  transfersTo         TableTransfer[]  @relation("TransferTo")
  transfersAuthorized TableTransfer[]  @relation("TransferAuthorizedByWaiter")

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([branchId, isActive])
  @@index([tenantId])
}

model TableTransfer {
  id                   String          @id @default(cuid())
  openTabId            String
  openTab              OpenTab         @relation(fields: [openTabId], references: [id], onDelete: Cascade)
  // Nullable (§118): "Mover mesa" aplica también a cuentas SIN mesonero
  // asignado (abiertas desde caja). La cesión mesonero→mesonero sí exige ambos.
  fromWaiterId         String?
  fromWaiter           Waiter?         @relation("TransferFrom", fields: [fromWaiterId], references: [id])
  toWaiterId           String?
  toWaiter             Waiter?         @relation("TransferTo", fields: [toWaiterId], references: [id])
  fromTableId          String?
  fromTable            TableOrStation? @relation("TransferFromTable", fields: [fromTableId], references: [id])
  toTableId            String?
  toTable              TableOrStation? @relation("TransferToTable", fields: [toTableId], references: [id])
  authorizedByWaiterId String?
  authorizedByWaiter   Waiter?         @relation("TransferAuthorizedByWaiter", fields: [authorizedByWaiterId], references: [id])
  authorizedByUserId   String?
  authorizedByUser     User?           @relation("TransferAuthorizedByUser", fields: [authorizedByUserId], references: [id])
  authorizedNote       String?
  reason               String?
  transferredAt        DateTime        @default(now())

  @@index([openTabId])
  @@index([fromWaiterId])
  @@index([toWaiterId])
  @@index([fromTableId])
  @@index([toTableId])
  @@index([authorizedByUserId])
}

model ServiceZone {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  code      String?
  name      String
  zoneType  String   @default("DINING") // DINING, BAR, TERRACE, VIP
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tablesOrStations TableOrStation[]
  openTabs         OpenTab[]
  salesOrders      SalesOrder[]

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([branchId, name])
  @@index([branchId, zoneType])
  @@index([tenantId])
}

model TableOrStation {
  id            String      @id @default(cuid())
  branchId      String
  branch        Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceZoneId String
  serviceZone   ServiceZone @relation(fields: [serviceZoneId], references: [id], onDelete: Cascade)
  code          String
  name          String
  stationType   String      @default("TABLE") // TABLE, BAR_SEAT, VIP_ROOM
  capacity      Int         @default(1)
  currentStatus String      @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED, OUT_OF_SERVICE
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  openTabs      OpenTab[]
  salesOrders   SalesOrder[]
  transfersFrom TableTransfer[] @relation("TransferFromTable")
  transfersTo   TableTransfer[] @relation("TransferToTable")

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([branchId, code])
  @@index([serviceZoneId, stationType])
  @@index([currentStatus])
  @@index([tenantId])
}

model OpenTab {
  id                 String          @id @default(cuid())
  branchId           String
  branch             Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceZoneId      String?
  serviceZone        ServiceZone?    @relation(fields: [serviceZoneId], references: [id])
  tableOrStationId   String?
  tableOrStation     TableOrStation? @relation(fields: [tableOrStationId], references: [id])
  tabCode            String // unique compuesto con tenantId abajo
  customerLabel      String?
  customerPhone      String?
  guestCount         Int             @default(1)
  status             String          @default("OPEN") // OPEN, PARTIALLY_PAID, CLOSED, CANCELLED
  serviceType        String          @default("TABLE_SERVICE") // TABLE_SERVICE, BAR_TAB, EVENT
  runningSubtotal    Float           @default(0)
  runningDiscount    Float           @default(0)
  runningTax         Float           @default(0)
  runningTotal       Float           @default(0)
  balanceDue         Float           @default(0)
  totalServiceCharge Float           @default(0) // Service charge acumulado de la mesa
  totalTip           Float           @default(0) // Propina voluntaria acumulada
  tipPercent         Float? // Propina seleccionada por el cliente (0, 10, 15, 20)
  tipAmount          Float? // tipPercent/100 × runningTotal (neto post-descuento) — ver §46
  dailyNumber        Int? // Número de orden del día de la mesa (§84); las comandas lo heredan
  dailyLabel         String? // Ej. "MS-14" — mismo en todas las comandas de la mesa
  version            Int             @default(0)
  openedAt           DateTime        @default(now())
  closedAt           DateTime?
  updatedAt          DateTime        @updatedAt
  notes              String?
  waiterLabel        String?
  openedById         String
  openedBy           User            @relation("OpenTabOpener", fields: [openedById], references: [id])
  assignedWaiterId   String?
  assignedWaiter     User?           @relation("OpenTabAssignee", fields: [assignedWaiterId], references: [id])
  waiterProfileId    String?
  waiterProfile      Waiter?         @relation(fields: [waiterProfileId], references: [id])
  closedById         String?
  closedBy           User?           @relation("OpenTabCloser", fields: [closedById], references: [id])

  orders        SalesOrder[]
  orderLinks    OpenTabOrder[]
  paymentSplits PaymentSplit[]
  subAccounts   TabSubAccount[]
  transfers     TableTransfer[]

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, tabCode])
  @@index([branchId, status])
  @@index([tableOrStationId])
  @@index([tenantId])
}

model OpenTabOrder {
  id           String     @id @default(cuid())
  openTabId    String
  openTab      OpenTab    @relation(fields: [openTabId], references: [id], onDelete: Cascade)
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now())

  @@unique([openTabId, salesOrderId])
  @@index([salesOrderId])
}

model PaymentSplit {
  id                  String         @id @default(cuid())
  openTabId           String
  openTab             OpenTab        @relation(fields: [openTabId], references: [id], onDelete: Cascade)
  salesOrderId        String?
  salesOrder          SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  // null = pago de la mesa completa; set = pago de una subcuenta específica
  subAccountId        String?
  subAccount          TabSubAccount? @relation(fields: [subAccountId], references: [id])
  splitLabel          String
  splitType           String         @default("EQUAL") // EQUAL, ITEM_BASED, CUSTOM
  paymentMethod       String?
  status              String         @default("PENDING") // PENDING, PAID, VOID
  subtotal            Float          @default(0)
  discount            Float          @default(0)
  tax                 Float          @default(0)
  serviceChargeAmount Float          @default(0) // Cargo de servicio prorrateado en este split
  tipAmount           Float          @default(0) // Propina prorrateada en este split
  total               Float          @default(0)
  paidAmount          Float          @default(0)
  // Dual currency (Reportes FASE B — BUG #3 del diagnóstico): monto Bs
  // equivalente y tasa BCV AL MOMENTO del cobro. Null en cobros históricos
  // (= "Bs no registrado"; los reportes NO reconvierten con tasa actual).
  amountBs            Float?
  exchangeRate        Float?
  createdAt           DateTime       @default(now())
  paidAt              DateTime?
  notes               String?

  @@index([openTabId, status])
  @@index([salesOrderId])
  @@index([subAccountId])
  @@index([paidAt])
}

// ─── SUBCUENTAS ──────────────────────────────────────────────────────────────
// Una subcuenta es una división lógica dentro de una mesa (OpenTab).
// Hasta 25 subcuentas por mesa. Cada una tiene su propio subtotal y service charge.
// Los ítems se asignan a subcuentas via SubAccountItem (pueden ser parciales: qty < order item qty).

model TabSubAccount {
  id        String  @id @default(cuid())
  openTabId String
  openTab   OpenTab @relation(fields: [openTabId], references: [id], onDelete: Cascade)

  label     String // "Cuenta 1", "Carlos", etc. — editable
  sortOrder Int    @default(0)
  status    String @default("OPEN") // OPEN | PAID | VOID

  // Totales propios (recalculados por el server action en cada mutación)
  subtotal      Float @default(0)
  serviceCharge Float @default(0) // siempre subtotal * 0.10
  total         Float @default(0) // subtotal + serviceCharge

  // Cobro (se populan cuando status = PAID)
  paidAmount    Float     @default(0)
  paymentMethod String?
  paidAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         SubAccountItem[]
  paymentSplits PaymentSplit[]

  @@index([openTabId, status])
}

model SubAccountItem {
  id           String        @id @default(cuid())
  subAccountId String
  subAccount   TabSubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)

  salesOrderItemId String
  salesOrderItem   SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Cascade)

  // Cantidad asignada a esta subcuenta (puede ser menor que SalesOrderItem.quantity)
  quantity  Int
  // Snapshot del precio al momento de asignar (unitPrice * quantity + modificadores prorrateados)
  lineTotal Float

  createdAt DateTime @default(now())

  @@index([subAccountId])
  @@index([salesOrderItemId])
}

// Líneas de pago de una orden (pagos mixtos: efectivo + zelle + punto, etc.)
model SalesOrderPayment {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  method       String // CASH | ZELLE | CARD | MOBILE_PAY | TRANSFER | CORTESIA
  amountUSD    Float
  amountBS     Float? // Monto en Bs si el pago fue en Bs
  exchangeRate Float? // Tasa usada para esta línea
  reference    String? // Número de referencia (transferencia, confirmación Zelle, etc.)
  createdAt    DateTime   @default(now())

  // Tesorería (Fase 0): cuenta bancaria a la que ENTRÓ/liquidó este pago. Nullable.
  // Se resuelve desde `method` vía PosTerminal.posMethodKey (entrada de la cuenta).
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([salesOrderId])
  @@index([bankAccountId])
}

// ============================================================================
// TASA DE CAMBIO USD / BOLÍVARES (BCV)
// ============================================================================

// ============================================================================
// CONFIGURACIÓN DEL SISTEMA (clave-valor persistente)
// ============================================================================
// Usada para guardar config de instalación sin depender de variables de entorno.
// Clave: 'enabled_modules' → valor: JSON array de ids de módulos activos.

model SystemConfig {
  id        String   @id @default(cuid()) // PK cuid — desde Lote multitenant para soportar misma `key` entre tenants
  key       String // 'enabled_modules', 'business_name', etc.
  value     String // JSON string o texto plano
  updatedAt DateTime @updatedAt
  updatedBy String? // userId quien lo cambió

  // Multi-tenant: `(tenantId, key)` es compound unique → cada tenant puede
  // tener su propia config con las mismas keys.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

// Contador global de correlativo por canal (nunca se resetea)
model InvoiceCounter {
  id        String   @id @default(cuid())
  channel   String
  // "DELIVERY" | "PICKUP" | "RESTAURANT" | "PEDIDOS_YA" | "OPEN_TAB" | "GAME_SESSION"
  lastValue Int      @default(100)
  updatedAt DateTime @updatedAt

  // Multi-tenant (Fase 1.D-γ).
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, channel])
