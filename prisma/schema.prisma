// ============================================================================
// FASE 2 — Modelos additive-only (Sub-Fase 2 micro, 2026-04-28)
// ----------------------------------------------------------------------------
// Estos modelos NO se han aplicado a la BD productiva todavía. El schema los
// declara para que el cliente Prisma generado tenga tipos disponibles y los
// servicios futuros puedan usarlos. La aplicación física de las tablas se
// hace con scripts/apply-phase2-migrations.ts ejecutado manualmente.
//
// Hasta que se apliquen, NO usar estas relaciones en queries de runtime
// (los include / where fallarían porque las tablas no existen).
// ============================================================================

/// Outbox para reintentar el descargo de inventario fallido (Fase 2 propuesta 001).
/// Ver prisma/migrations-proposed/001_inventory_deduction_retry.sql
model InventoryDeductionRetry {
  id           String      @id @default(cuid())
  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)

  payload       String // JSON serializado del cart snapshot
  status        String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | FAILED | CANCELLED
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  lastError     String?
  nextRetryAt   DateTime
  lastAttemptAt DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelledById String?
  cancelledBy   User?     @relation("DeductionRetryCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([nextRetryAt])
  @@index([status, nextRetryAt])
  @@index([salesOrderId])
}

/// Histórico de precios por par (Supplier, InventoryItem) — Fase 2 propuesta 002.
/// Ver prisma/migrations-proposed/002_supplier_item_price_history.sql
/// El índice único parcial WHERE effectiveTo IS NULL se crea en la migración SQL
/// (Prisma no soporta filtered unique indexes nativamente todavía).
model SupplierItemPriceHistory {
  id              String        @id @default(cuid())
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  unitPrice     Float
  currency      String    @default("USD")
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  registeredFromPurchaseOrderId String?
  registeredFromPurchaseOrder   PurchaseOrder? @relation(fields: [registeredFromPurchaseOrderId], references: [id], onDelete: SetNull)

  registeredById String?
  registeredBy   User?    @relation("SupplierPriceRegisteredBy", fields: [registeredById], references: [id], onDelete: SetNull)
  notes          String?
  createdAt      DateTime @default(now())

  @@index([supplierId])
  @@index([inventoryItemId])
  @@index([effectiveFrom])
  @@index([supplierId, inventoryItemId])
}

// ============================================================================
// RATE LIMITING (PR 2 — hardening de auth)
// ============================================================================

/// Buckets de rate limiting con sliding fixed-window.
/// La key es un identificador del recurso/actor (ej. "login:ip:email", "pin-waiter:ip").
/// windowStart es el inicio del intervalo redondeado al ancho de ventana.
/// Cleanup periódico vía DELETE WHERE expiresAt < NOW (manual o cron).
model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  count       Int      @default(1)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([key, windowStart])
  @@index([expiresAt])
}

// ============================================================================
// PRINT AGENT (§38 — daemon que traduce print jobs a ESC/POS)
// ============================================================================

/// Cola de trabajos de impresión que el Print Agent (corriendo en una PC
/// del restaurante) procesa polling cada ~1s. El ERP encola, el agent
/// despacha. Permite imprimir desde tablets que no tienen drivers de la
/// térmica AON.
model PrintJob {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  type    PrintJobType
  station String?
  payload Json

  status       PrintJobStatus @default(PENDING)
  retries      Int            @default(0)
  errorMessage String?

  // §104 — Impresión DIFERIDA (pedidos futuros): el job queda PENDING pero el
  // API no lo entrega al print-agent hasta que scheduledFor <= now(). Null =
  // imprimir ya (comportamiento histórico intacto). El agente no cambia:
  // sondea cada ~1s y el job "aparece" a la hora asignada.
  scheduledFor DateTime?

  createdAt   DateTime  @default(now())
  claimedAt   DateTime?
  completedAt DateTime?

  enqueuedById String?
  enqueuedBy   User?   @relation("PrintJobEnqueuedBy", fields: [enqueuedById], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, status, scheduledFor])
  @@index([tenantId, completedAt])
}

enum PrintJobType {
  RECEIPT
  PRECUENTA
  KITCHEN
  VOID_KITCHEN
}

enum PrintJobStatus {
  PENDING
  PRINTING
  COMPLETED
  FAILED
}

// ============================================================================
// CLIENTES (Customer)
// ============================================================================
// Tabla de clientes recurrentes. El POS Delivery busca aquí por cédula o
// nombre y autollena datos al ingresar un pedido. No se vincula a User
// (el cliente no se loguea en la app, solo es referencia de contacto).
model Customer {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  fullName   String // "Julio Acosta" (obligatorio)
  idDocument String? // "V-12345678", "E-...", "J-...". Opcional (turistas).
  phone      String? // "04241234567"
  email      String?
  address    String? // dirección por defecto para delivery
  notes      String? // preferencias, alergias, etc.

  // Stats (cache, se actualizan al crear órdenes). Optional para no
  // requerir backfill inmediato si se importan clientes desde Excel.
  totalOrders Int       @default(0)
  totalSpent  Float     @default(0)
  lastOrderAt DateTime?

  isActive Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Ventas vinculadas (CRM — Cartera de Clientes). Las stats cacheadas de
  // arriba se actualizan al cobrar; el historial real se lee desde acá.
  salesOrders SalesOrder[]

  // Órdenes de delivery vinculadas (módulo aislado). Link best-effort por
  // teléfono; NO actualiza las stats POS de arriba (totalSpent/totalOrders).
  deliveryOrders DeliveryOrder[]

  @@unique([tenantId, idDocument])
  @@index([tenantId])
  @@index([tenantId, fullName])
  @@index([tenantId, phone])
}

// ============================================================================
// MÓDULO GESTIÓN DE DELIVERYS (feature flag deliveryOps) — MÓDULO AISLADO
// ============================================================================
// Operación de delivery orquestada por un bot (n8n + IA). KPSULA es la fuente
// determinística: correlativos, asignación de sede, estados, impresión.
//
// AISLADO: NO escribe en SalesOrder, NO entra al Report Z / historial de
// ventas (§20), NI descarga inventario. La contabilidad del delivery se lleva
// aparte (decisión futura). Plan completo: docs/DELIVERY_OPS_PLAN.md.

/// Config a nivel tenant: prefijo + contador atómico de correlativo, modo de
/// validación de pago y destino de webhooks. 1:1 con Tenant.
model DeliveryTenantConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  correlativePrefix String  @default("PP") // "PP-00127"
  nextCorrelative   Int     @default(1) // contador atómico (incremento en transacción)
  validationMode    String  @default("MANUAL") // MANUAL | AUTO (antifraude: arrancar MANUAL)
  webhookUrl        String? // destino de webhooks salientes a n8n
  schedule          Json? // horarios de atención (global o por sede)
  isActive          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Config de delivery por sede. 1:1 con Branch (no se engorda Branch, que lo
/// comparte el POS restaurante de todos los tenants).
model BranchDeliveryConfig {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId String @unique
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  lat            Float?
  lon            Float?
  printerStation String? // string `station` que consume el Print Agent (§39)
  whatsappGroup  String? // id/nombre del grupo de motorizados (Evolution API)
  managerUserId  String? // gerente responsable de la sede (scalar; sin FK a User)
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

/// Zona de cobertura geográfica de una sede (El Hatillo, La Lagunita, etc.).
/// NO reusa ServiceZone (esa es DINING/BAR/VIP físico dentro del local).
model DeliveryZone {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name     String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, name])
  @@index([tenantId])
}

/// La orden de delivery (entidad central). Máquina de estados propia,
/// independiente de SalesOrder. Nace sin cajera, antes del pago.
model DeliveryOrder {
  id          String @id @default(cuid())
  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  correlative String // "PP-00127" — único por tenant

  branchId String? // sede asignada (null hasta resolver)
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Canal / origen (del bot)
  channel String // telegram | whatsapp
  chatId  String?

  // Cliente (best-effort, sin contaminar stats POS del Customer)
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String?
  customerPhone   String?
  deliveryAddress String?
  deliveryRef     String? // punto de referencia
  lat             Float?
  lon             Float?

  // Comanda y montos (INFORMATIVOS — no contables)
  comanda      Json // el JSON que emite el bot
  totalUsd     Float?
  totalBs      Float?
  exchangeRate Float?

  // Estado (máquina de estados — ver src/lib/delivery/state-machine.ts)
  // ESPERANDO_PAGO | PAGO_POR_VALIDAR | EN_COCINA | LISTA | EN_CAMINO | ENTREGADA | CANCELADA
  status String @default("ESPERANDO_PAGO")

  // Idempotencia (dedupe del bot): hash de canal+chatId+items, ventana 10 min
  itemsHash String?

  // Comprobante de pago (Fase 2)
  paymentProofPath     String?
  paymentProofType     String? // billetes | pago_movil | transferencia
  paymentValidatedById String? // scalar; sin FK a User
  paymentValidatedAt   DateTime?

  // Motorizado (Fase 3)
  driverId   String?
  driver     DeliveryDriver? @relation(fields: [driverId], references: [id], onDelete: SetNull)
  assignedAt DateTime?

  // Cancelación
  cancelReason  String?
  cancelledById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events DeliveryOrderEvent[]

  @@unique([tenantId, correlative])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, channel, chatId])
  @@index([branchId, status])
  @@index([tenantId, customerPhone])
}

/// Motorizado (repartidor) del tenant. Puede estar asociado a una sede.
model DeliveryDriver {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name     String
  phone    String
  status   String  @default("AVAILABLE") // AVAILABLE | ON_ROUTE | OFFLINE
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders DeliveryOrder[]

  @@index([tenantId])
  @@index([branchId, status])
}

/// Outbox de webhooks salientes (KPSULA → n8n). Entrega confiable con
/// reintentos por el cron /api/cron/deliver-webhooks (patrón §18.40/41).
model DeliveryWebhookOutbox {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event     String // orden.en_cocina | orden.lista | orden.en_camino | orden.entregada
  payload   Json
  status    String  @default("PENDING") // PENDING | SENT | FAILED
  attempts  Int     @default(0)
  lastError String?

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([tenantId, status, createdAt])
}

/// Agotados / falta de stock por sede (capa estructurada, §9). El gerente
/// marca un ítem (por etiqueta) como no disponible en su sede; alimenta
/// GET /contexto para que el bot deje de ofrecerlo. Label-based (decoupled del
/// menú) — coincide con el shape del contexto: { sede_id, item }.
model ItemAvailability {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  itemLabel   String
  available   Boolean @default(true)
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, itemLabel])
  @@index([tenantId, branchId, available])
}

/// Notas de texto libre del gerente (capa de texto libre, §9). Aditivas y
/// orientativas: se inyectan en {NOTAS_GERENTE} del prompt. Alcance global
/// (branchId null) o por sede; con on/off y vigencia (expiresAt) para que no
/// queden instrucciones viejas activas.
model ManagerNote {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  text        String
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, isActive])
}

/// Reglas de ruteo producto → sede (capa estructurada, §9). Si la comanda
/// incluye `matchProduct`, la orden nace en `branchId` (se aplica en
/// POST /ordenes, NO en la IA). Mayor prioridad gana.
model RoutingRule {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matchProduct String
  branchId     String
  branch       Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  priority     Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, isActive])
}

/// Auditoría de transiciones de estado de una orden. Sin tenantId: aísla vía
/// FK a DeliveryOrder (mismo patrón que SalesOrderPayment). Da métricas de
/// tiempo por etapa gratis.
model DeliveryOrderEvent {
  id        String        @id @default(cuid())
  orderId   String
  order     DeliveryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromState String?
  toState   String
  userId    String? // null = lo hizo n8n/bot
  note      String?
  createdAt DateTime      @default(now())

  @@index([orderId, createdAt])
}

/// SaaS billing — registro manual de pagos que cada tenant le hace al
/// operador del SaaS (vos). NO multi-tenant a nivel app: solo SUPER_ADMIN
/// consulta y escribe vía prisma directo en /admin/tenants/[id].
/// Si querés cobrar más tarde con plan + suspensión automática, este modelo
/// se extiende con `dueAt`, `status`, etc. — por ahora minimal.
model TenantPayment {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount       Float
  currency     String    @default("USD") // USD, BSD, EUR, etc.
  paidAt       DateTime
  method       String // cash, transfer, zelle, crypto, pdv, etc.
  periodStart  DateTime? // opcional: cubre desde
  periodEnd    DateTime? // opcional: cubre hasta
  note         String?
  recordedById String
  recordedBy   User      @relation("TenantPaymentRecorder", fields: [recordedById], references: [id])
  createdAt    DateTime  @default(now())

  @@index([tenantId, paidAt])
  @@index([recordedById])
}

// ============================================================================
// CONVERSACIONES WHATSAPP (Cloud API Meta) — bandeja humana + bot Fabiola/n8n
// ============================================================================
// Kpsula es la fuente de verdad de las conversaciones y el panel humano.
// El bot vive en n8n y consulta /api/v1/wa/.../control antes de responder.
// Compliance (ventana 24h, plantillas, opt-in/out) en src/lib/wa/compliance.ts.

enum ConversationStatus {
  BOT // Fabiola responde
  HUMAN // un humano tomó el control
  CLOSED // cerrada/archivada
}

enum MessageDirection {
  INBOUND // cliente → negocio
  OUTBOUND // negocio → cliente (bot o humano)
}

enum MessageSenderType {
  CUSTOMER
  BOT
  HUMAN
}

enum MessageKind {
  TEXT
  IMAGE
  DOCUMENT
  LOCATION
  TEMPLATE
  AUDIO
  UNSUPPORTED
}

enum WaDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum TemplateApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
}

model WaConversation {
  id               String             @id @default(cuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  branchId         String?
  waId             String // wa_id del cliente (número E.164 sin +)
  customerName     String?
  customerPhone    String // igual a waId, redundante para búsquedas
  status           ConversationStatus @default(BOT)
  assignedToUserId String? // usuario Kpsula que tomó el control

  // ── Compliance ventana 24h ──────────────────────────────────────────────
  lastCustomerMsgAt DateTime? // último mensaje ENTRANTE del cliente
  windowExpiresAt   DateTime? // lastCustomerMsgAt + 24h (persistido para queries)

  // ── Opt-in / Opt-out ────────────────────────────────────────────────────
  marketingOptIn Boolean   @default(false)
  optedOutAt     DateTime? // cliente pidió BAJA/STOP → bloqueo de salientes no-obligatorios

  // ── Vínculos de negocio ─────────────────────────────────────────────────
  lastOrderId String? // última orden de delivery creada desde esta conversación
  unreadCount Int     @default(0) // no leídos por humanos (badge en bandeja)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages WaMessage[]

  @@unique([tenantId, waId])
  @@index([tenantId, status, updatedAt])
}

model WaMessage {
  id             String         @id @default(cuid())
  tenantId       String
  conversationId String
  conversation   WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  direction    MessageDirection
  senderType   MessageSenderType
  senderUserId String? // si senderType=HUMAN
  kind         MessageKind
  body         String? @db.Text // texto, caption, o payload serializado
  mediaUrl     String? // URL local ya descargada (media de Meta expira)
  mediaMimeType String?
  latitude     Float?
  longitude    Float?
  templateName String? // si kind=TEMPLATE

  wamid          String?          @unique // id de mensaje de Meta (correlaciona estados)
  deliveryStatus WaDeliveryStatus @default(QUEUED)
  errorDetail    String? // si FAILED, el error de Graph API

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([tenantId, wamid])
}

model WaTemplate {
  id             String                 @id @default(cuid())
  tenantId       String
  tenant         Tenant                 @relation("TenantWaTemplates", fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  name           String // nombre exacto registrado en Meta (ej. confirmacion_pedido)
  language       String                 @default("es")
  category       String // UTILITY | MARKETING | AUTHENTICATION
  bodyPreview    String                 @db.Text // texto con {{1}}, {{2}} para preview
  variablesCount Int                    @default(0)
  approvalStatus TemplateApprovalStatus @default(DRAFT)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([tenantId, name, language])
}

model WaCredential {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  tenant          Tenant  @relation("TenantWaCredential", fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  phoneNumberId   String
  wabaId          String
  accessToken     String  @db.Text // cifrado en reposo (AES-256-GCM, WA_TOKEN_ENC_KEY)
  appSecret       String // para validar firmas si Kpsula recibe webhooks directos
  displayPhone    String? // +58 4XX ... para mostrar en UI
  graphApiVersion String  @default("v21.0")
  active          Boolean @default(true)
}

/// §108 — Cambio de divisas (Finanzas). Registra una operación de cambio:
/// sale un monto en la moneda origen (típico: USD de la caja o Zelle) y
/// entra el equivalente en la moneda destino repartido en una o más
/// cuentas bancarias. La tasa implícita queda auditada (Bs por USD).
model CurrencyExchange {
  id String @id @default(cuid())

  exchangeDate DateTime
  // Moneda/monto que SALE (egreso) y que ENTRA (ingreso).
  currencyOut String @default("USD") // USD | BS
  amountOut   Float
  currencyIn  String @default("BS") // BS | USD
  amountIn    Float // = suma de destinations.amount
  rate        Float // tasa implícita Bs por USD

  // Cuenta de la que sale el dinero (opcional: efectivo sin cuenta).
  fromAccountId String?
  fromAccount   BankAccount? @relation("CurrencyExchangeFrom", fields: [fromAccountId], references: [id])

  notes  String?
  status String  @default("ACTIVE") // ACTIVE | VOID
  voidReason String?

  createdById String
  createdBy   User     @relation("CurrencyExchangeCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  destinations CurrencyExchangeDestination[]

  @@index([tenantId])
  @@index([exchangeDate])
  @@index([status])
  @@index([fromAccountId])
}

/// Destino de un cambio de divisas: a qué cuenta bancaria entró qué monto
/// (en la moneda destino del cambio). Sin tenantId: hereda vía el cambio.
model CurrencyExchangeDestination {
  id                 String           @id @default(cuid())
  currencyExchangeId String
  currencyExchange   CurrencyExchange @relation(fields: [currencyExchangeId], references: [id], onDelete: Cascade)

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])

  amount    Float // en currencyIn del cambio
  reference String? // nº de transferencia / depósito

  @@index([currencyExchangeId])
  @@index([bankAccountId])
}

/// §113 — Encuesta de satisfacción del cliente, llenada por el mesonero/caja
/// desde la tablet al final del servicio (al cerrar la cuenta o manualmente).
/// No bloquea el cobro: es un registro opcional, omitible.
///
/// `rating` es la calificación GENERAL (siempre presente). Las columnas de
/// dimensión (food/service/ambiance) quedan nullable para poder pasar a una
/// encuesta multi-dimensión más adelante sin migración destructiva.
model SatisfactionSurvey {
  id String @id @default(cuid())

  // Vínculo a la mesa (snapshot: la mesa puede cerrarse/reabrirse).
  openTabId  String?
  tabCode    String? // ej. "TAB-3691"
  tableName  String? // ej. "SP-09"
  waiterName String? // mesonero atribuido a la mesa

  /// Calificación general: EXCELENTE | BUENA | REGULAR | MALA.
  rating String

  /// Dimensiones opcionales (misma escala) — reservadas para el futuro.
  foodRating    String?
  serviceRating String?
  ambianceRating String?

  /// Comentario libre opcional (cuando la respuesta no es la esperada).
  comment String?

  createdById   String
  createdBy     User   @relation("SatisfactionSurveyCreator", fields: [createdById], references: [id])
  createdByName String // snapshot del nombre de quien la registró
  createdAt     DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([tenantId])
  @@index([createdAt])
  @@index([rating])
  @@index([openTabId])
}

/// §115 — Anticipo (abono) a un proveedor SIN factura todavía.
/// Caso: "pago ahorita y me facturan mañana". El efectivo sale al crearlo
/// (cuenta como egreso una sola vez). Cuando llega la factura, se aplica el
/// anticipo generando un AccountPayment isCash=false (no vuelve a contar).
model SupplierAdvance {
  id String @id @default(cuid())

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  amountUsd     Float
  amountBs      Float?
  exchangeRate  Float?
  paymentMethod String
  paymentRef    String?
  paidAt        DateTime

  /// Cuánto del anticipo ya se aplicó a facturas. remaining = amount - applied.
  appliedAmountUsd Float  @default(0)
  status           String @default("OPEN") // OPEN | APPLIED | VOID
  voidReason       String?

  notes String?

  createdById String
  createdBy   User     @relation("SupplierAdvanceCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Aplicaciones de este anticipo a facturas (AccountPayment isCash=false).
  applications AccountPayment[]

  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
  @@index([paidAt])
}
