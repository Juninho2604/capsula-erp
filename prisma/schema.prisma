// ============================================================================
// FASE 2 — Modelos additive-only (Sub-Fase 2 micro, 2026-04-28)
// ----------------------------------------------------------------------------
// Estos modelos NO se han aplicado a la BD productiva todavía. El schema los
// declara para que el cliente Prisma generado tenga tipos disponibles y los
// servicios futuros puedan usarlos. La aplicación física de las tablas se
// hace con scripts/apply-phase2-migrations.ts ejecutado manualmente.
//
// Hasta que se apliquen, NO usar estas relaciones en queries de runtime
// (los include / where fallarían porque las tablas no existen).
// ============================================================================

/// Outbox para reintentar el descargo de inventario fallido (Fase 2 propuesta 001).
/// Ver prisma/migrations-proposed/001_inventory_deduction_retry.sql
model InventoryDeductionRetry {
  id           String      @id @default(cuid())
  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)

  payload       String // JSON serializado del cart snapshot
  status        String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | FAILED | CANCELLED
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  lastError     String?
  nextRetryAt   DateTime
  lastAttemptAt DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelledById String?
  cancelledBy   User?     @relation("DeductionRetryCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([nextRetryAt])
  @@index([status, nextRetryAt])
  @@index([salesOrderId])
}

/// Histórico de precios por par (Supplier, InventoryItem) — Fase 2 propuesta 002.
/// Ver prisma/migrations-proposed/002_supplier_item_price_history.sql
/// El índice único parcial WHERE effectiveTo IS NULL se crea en la migración SQL
/// (Prisma no soporta filtered unique indexes nativamente todavía).
model SupplierItemPriceHistory {
  id              String        @id @default(cuid())
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  unitPrice     Float
  currency      String    @default("USD")
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  registeredFromPurchaseOrderId String?
  registeredFromPurchaseOrder   PurchaseOrder? @relation(fields: [registeredFromPurchaseOrderId], references: [id], onDelete: SetNull)

  registeredById String?
  registeredBy   User?    @relation("SupplierPriceRegisteredBy", fields: [registeredById], references: [id], onDelete: SetNull)
  notes          String?
  createdAt      DateTime @default(now())

  @@index([supplierId])
  @@index([inventoryItemId])
  @@index([effectiveFrom])
  @@index([supplierId, inventoryItemId])
}

// ============================================================================
// RATE LIMITING (PR 2 — hardening de auth)
// ============================================================================

/// Buckets de rate limiting con sliding fixed-window.
/// La key es un identificador del recurso/actor (ej. "login:ip:email", "pin-waiter:ip").
/// windowStart es el inicio del intervalo redondeado al ancho de ventana.
/// Cleanup periódico vía DELETE WHERE expiresAt < NOW (manual o cron).
model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  count       Int      @default(1)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([key, windowStart])
  @@index([expiresAt])
}

// ============================================================================
// PRINT AGENT (§38 — daemon que traduce print jobs a ESC/POS)
// ============================================================================

/// Cola de trabajos de impresión que el Print Agent (corriendo en una PC
/// del restaurante) procesa polling cada ~1s. El ERP encola, el agent
/// despacha. Permite imprimir desde tablets que no tienen drivers de la
/// térmica AON.
model PrintJob {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  type    PrintJobType
  station String?
  payload Json

  status       PrintJobStatus @default(PENDING)
  retries      Int            @default(0)
  errorMessage String?

  createdAt   DateTime  @default(now())
  claimedAt   DateTime?
  completedAt DateTime?

  enqueuedById String?
  enqueuedBy   User?   @relation("PrintJobEnqueuedBy", fields: [enqueuedById], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, completedAt])
}

enum PrintJobType {
  RECEIPT
  PRECUENTA
  KITCHEN
  VOID_KITCHEN
}

enum PrintJobStatus {
  PENDING
  PRINTING
  COMPLETED
  FAILED
}

// ============================================================================
// CLIENTES (Customer)
// ============================================================================
// Tabla de clientes recurrentes. El POS Delivery busca aquí por cédula o
// nombre y autollena datos al ingresar un pedido. No se vincula a User
// (el cliente no se loguea en la app, solo es referencia de contacto).
model Customer {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  fullName   String // "Julio Acosta" (obligatorio)
  idDocument String? // "V-12345678", "E-...", "J-...". Opcional (turistas).
  phone      String? // "04241234567"
  email      String?
  address    String? // dirección por defecto para delivery
  notes      String? // preferencias, alergias, etc.

  // Stats (cache, se actualizan al crear órdenes). Optional para no
  // requerir backfill inmediato si se importan clientes desde Excel.
  totalOrders Int       @default(0)
  totalSpent  Float     @default(0)
  lastOrderAt DateTime?

  isActive Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Ventas vinculadas (CRM — Cartera de Clientes). Las stats cacheadas de
  // arriba se actualizan al cobrar; el historial real se lee desde acá.
  salesOrders SalesOrder[]

  // Órdenes de delivery vinculadas (módulo aislado). Link best-effort por
  // teléfono; NO actualiza las stats POS de arriba (totalSpent/totalOrders).
  deliveryOrders DeliveryOrder[]

  @@unique([tenantId, idDocument])
  @@index([tenantId])
  @@index([tenantId, fullName])
  @@index([tenantId, phone])
}

// ============================================================================
// MÓDULO GESTIÓN DE DELIVERYS (feature flag deliveryOps) — MÓDULO AISLADO
// ============================================================================
// Operación de delivery orquestada por un bot (n8n + IA). KPSULA es la fuente
// determinística: correlativos, asignación de sede, estados, impresión.
//
// AISLADO: NO escribe en SalesOrder, NO entra al Report Z / historial de
// ventas (§20), NI descarga inventario. La contabilidad del delivery se lleva
// aparte (decisión futura). Plan completo: docs/DELIVERY_OPS_PLAN.md.

/// Config a nivel tenant: prefijo + contador atómico de correlativo, modo de
/// validación de pago y destino de webhooks. 1:1 con Tenant.
model DeliveryTenantConfig {
  id                String @id @default(cuid())
  tenantId          String @unique
  tenant            Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  correlativePrefix String  @default("PP") // "PP-00127"
  nextCorrelative   Int     @default(1)     // contador atómico (incremento en transacción)
  validationMode    String  @default("MANUAL") // MANUAL | AUTO (antifraude: arrancar MANUAL)
  webhookUrl        String? // destino de webhooks salientes a n8n
  schedule          Json?   // horarios de atención (global o por sede)
  isActive          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Config de delivery por sede. 1:1 con Branch (no se engorda Branch, que lo
/// comparte el POS restaurante de todos los tenants).
model BranchDeliveryConfig {
  id             String  @id @default(cuid())
  tenantId       String
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId       String  @unique
  branch         Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  lat            Float?
  lon            Float?
  printerStation String? // string `station` que consume el Print Agent (§39)
  whatsappGroup  String? // id/nombre del grupo de motorizados (Evolution API)
  managerUserId  String? // gerente responsable de la sede (scalar; sin FK a User)
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

/// Zona de cobertura geográfica de una sede (El Hatillo, La Lagunita, etc.).
/// NO reusa ServiceZone (esa es DINING/BAR/VIP físico dentro del local).
model DeliveryZone {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, name])
  @@index([tenantId])
}

/// La orden de delivery (entidad central). Máquina de estados propia,
/// independiente de SalesOrder. Nace sin cajera, antes del pago.
model DeliveryOrder {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  correlative String  // "PP-00127" — único por tenant

  branchId String? // sede asignada (null hasta resolver)
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Canal / origen (del bot)
  channel String  // telegram | whatsapp
  chatId  String?

  // Cliente (best-effort, sin contaminar stats POS del Customer)
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String?
  customerPhone   String?
  deliveryAddress String?
  deliveryRef     String? // punto de referencia
  lat             Float?
  lon             Float?

  // Comanda y montos (INFORMATIVOS — no contables)
  comanda      Json   // el JSON que emite el bot
  totalUsd     Float?
  totalBs      Float?
  exchangeRate Float?

  // Estado (máquina de estados — ver src/lib/delivery/state-machine.ts)
  // ESPERANDO_PAGO | PAGO_POR_VALIDAR | EN_COCINA | LISTA | EN_CAMINO | ENTREGADA | CANCELADA
  status String @default("ESPERANDO_PAGO")

  // Idempotencia (dedupe del bot): hash de canal+chatId+items, ventana 10 min
  itemsHash String?

  // Comprobante de pago (Fase 2)
  paymentProofPath     String?
  paymentProofType     String? // billetes | pago_movil | transferencia
  paymentValidatedById String? // scalar; sin FK a User
  paymentValidatedAt   DateTime?

  // Motorizado (Fase 3 — driverId scalar por ahora; FK/relación en Fase 3)
  driverId   String?
  assignedAt DateTime?

  // Cancelación
  cancelReason  String?
  cancelledById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events DeliveryOrderEvent[]

  @@unique([tenantId, correlative])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, channel, chatId])
  @@index([branchId, status])
  @@index([tenantId, customerPhone])
}

/// Auditoría de transiciones de estado de una orden. Sin tenantId: aísla vía
/// FK a DeliveryOrder (mismo patrón que SalesOrderPayment). Da métricas de
/// tiempo por etapa gratis.
model DeliveryOrderEvent {
  id        String        @id @default(cuid())
  orderId   String
  order     DeliveryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromState String?
  toState   String
  userId    String? // null = lo hizo n8n/bot
  note      String?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

/// SaaS billing — registro manual de pagos que cada tenant le hace al
/// operador del SaaS (vos). NO multi-tenant a nivel app: solo SUPER_ADMIN
/// consulta y escribe vía prisma directo en /admin/tenants/[id].
/// Si querés cobrar más tarde con plan + suspensión automática, este modelo
/// se extiende con `dueAt`, `status`, etc. — por ahora minimal.
model TenantPayment {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount       Float
  currency     String    @default("USD") // USD, BSD, EUR, etc.
  paidAt       DateTime
  method       String // cash, transfer, zelle, crypto, pdv, etc.
  periodStart  DateTime? // opcional: cubre desde
  periodEnd    DateTime? // opcional: cubre hasta
  note         String?
  recordedById String
  recordedBy   User      @relation("TenantPaymentRecorder", fields: [recordedById], references: [id])
  createdAt    DateTime  @default(now())

  @@index([tenantId, paidAt])
  @@index([recordedById])
}
