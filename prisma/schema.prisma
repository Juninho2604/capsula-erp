// ============================================================================
// SHANKLISH CARACAS ERP - PRISMA SCHEMA
// ============================================================================
// Base de Datos: Google Cloud SQL (PostgreSQL)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USUARIOS Y AUTENTICACIÃ“N
// ============================================================================

/// Multi-tenant root entity. Cada restaurante (o cadena) que use el SaaS
/// es un Tenant. Por ahora la tabla existe pero no se usa todavía en queries
/// — se introduce de forma additive para permitir migración por fases.
/// El registro inicial 'shanklish' se siembra en la migration 1.A.
model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Branding fiscal/visual del tenant ────────────────────────────────────
  // Todos OPCIONALES — un tenant nuevo arranca con null y NO imprime nada
  // en esos campos en recibos. Backfill manual desde panel admin (futuro)
  // o vía SQL update por ahora. Para Shanklish se backfillean en la
  // migration `20260523180000_add_tenant_branding` con los valores que
  // estaban hardcoded en print-command.ts.
  //
  // legalName:   razón social impresa en recibos (ej. "Shanklish Caracas, C.A.")
  // taxId:       RIF/NIT/CIF (texto libre, ej. "J413087278" o "J-41308727-8")
  // logoUrl:     path relativo (/logo-x.png en public/) o absoluto (https://...)
  // displayName: nombre corto para headers de UI (POS Delivery, filename
  //              de exports). Si null, fallback a `name`. Permite mostrar
  //              "Shanklish" en headers donde el name completo
  //              "Shanklish Caracas" sería redundante.
  legalName   String?
  taxId       String?
  logoUrl     String?
  displayName String?

  // Feature flags por tenant. Catálogo de claves válidas en
  // `src/lib/feature-flags.ts` (FEATURE_FLAGS). Default `{}` = todo apagado.
  // Los flags se prenden/apagan en `/dashboard/config/feature-flags` (solo
  // OWNER). Sirven como kill switch sin redeploy: si una feature nueva
  // rompe en producción, se baja el flag desde la UI.
  featureFlags Json @default("{}")

  // Relaciones inversas (multi-tenant Fase 1.B+).
  // Todas opcionales por ahora; al completar la migración cada fila tendrá
  // tenantId y se aplicará NOT NULL en una migration posterior.
  menuCategories       MenuCategory[]
  menuItems            MenuItem[]
  recipes              Recipe[]
  suppliers            Supplier[]
  expenseCategories    ExpenseCategory[]
  productFamilies      ProductFamily[]
  // Lote 1.D-α (bajo riesgo)
  inventoryItems       InventoryItem[]
  menuModifierGroups   MenuModifierGroup[]
  menuModifiers        MenuModifier[]
  exchangeRates        ExchangeRate[]
  auditLogs            AuditLog[]
  broadcastMessages    BroadcastMessage[]
  gameTypes            GameType[]
  wristbandPlans       WristbandPlan[]
  skuCreationTemplates SkuCreationTemplate[]
  queueTickets         QueueTicket[]
  // Lote 1.D-β (riesgo medio)
  expenses             Expense[]
  accountsPayable      AccountPayable[]
  accountPayments      AccountPayment[]
  purchaseOrders       PurchaseOrder[]
  productionOrders     ProductionOrder[]
  proteinProcessings   ProteinProcessing[]
  requisitions         Requisition[]
  inventoryAudits      InventoryAudit[]
  inventoryLoans       InventoryLoan[]
  inventoryCycles      InventoryCycle[]
  dailyInventories     DailyInventory[]
  cashRegisters        CashRegister[]
  // Lote 1.D-γ (riesgo alto — POS crítico)
  users                User[]
  branches             Branch[]
  areas                Area[]
  serviceZones         ServiceZone[]
  tableOrStations      TableOrStation[]
  openTabs             OpenTab[]
  salesOrders          SalesOrder[]
  salesOrderItems      SalesOrderItem[]
  waiters              Waiter[]
  gameStations         GameStation[]
  gameSessions         GameSession[]
  invoiceCounters      InvoiceCounter[]
  systemConfigs        SystemConfig[]
  reservations         Reservation[]
  printJobs            PrintJob[]
  customers            Customer[]
  // SaaS billing — pagos del tenant al operador del SaaS. NO multi-tenant
  // a nivel app: solo SUPER_ADMIN consulta vía prisma directo.
  tenantPayments       TenantPayment[]
  promotions           Promotion[]
  // Conteo físico semanal como entidad (§51.A)
  weeklyCounts         WeeklyCount[]
  // Módulo Gestión de Deliverys (feature flag deliveryOps). Módulo AISLADO:
  // no toca SalesOrder, Report Z ni inventario. Ver docs/DELIVERY_OPS_PLAN.md.
  deliveryOrders         DeliveryOrder[]
  deliveryZones          DeliveryZone[]
  branchDeliveryConfigs  BranchDeliveryConfig[]
  deliveryTenantConfig   DeliveryTenantConfig?
}

model User {
  id             String   @id @default(cuid())
  email          String
  passwordHash   String?
  firstName      String
  lastName       String
  role           String   @default("CHEF") // OWNER, AUDITOR, ADMIN_MANAGER, OPS_MANAGER, CHEF, AREA_LEAD, CASHIER (unified)
  pin            String? // Código de 4-6 dígitos para autorización rápida en POS
  allowedModules String? // JSON array de módulos permitidos (null = acceso por rol)
  grantedPerms   String? // JSON array de PERM keys que amplían el rol (ej: ["VOID_ORDER"])
  revokedPerms   String? // JSON array de PERM keys revocados del rol base (ej: ["EXPORT_SALES"])
  tokenVersion   Int      @default(0) // Se incrementa al cambiar rol/permisos/password para invalidar JWTs vivos
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Relaciones
  inventoryMovements InventoryMovement[]
  costHistories      CostHistory[]
  productionOrders   ProductionOrder[]

  // Requisiciones
  requisitionsRequested  Requisition[] @relation("RequisitionRequester")
  requisitionsProcessed  Requisition[] @relation("RequisitionProcessor")
  requisitionsDispatched Requisition[] @relation("RequisitionDispatcher")
  requisitionsReceived   Requisition[] @relation("RequisitionReceiver")

  // POS - Ventas
  salesOrders         SalesOrder[]     @relation("SalesOrderCreator")
  authorizedOrders    SalesOrder[]     @relation("SalesOrderAuthorizer")
  authorizedTransfers TableTransfer[]  @relation("TransferAuthorizedByUser")
  voidedOrders        SalesOrder[]     @relation("SalesOrderVoider")
  voidedItems         SalesOrderItem[] @relation("ItemVoidedByUser")
  openedTabs          OpenTab[]        @relation("OpenTabOpener")
  assignedTabs        OpenTab[]        @relation("OpenTabAssignee")
  closedTabs          OpenTab[]        @relation("OpenTabCloser")

  // Print Agent — jobs encolados por este usuario.
  enqueuedPrintJobs PrintJob[] @relation("PrintJobEnqueuedBy")

  // Clientes recurrentes creados por este usuario.
  createdCustomers Customer[] @relation("CustomerCreatedBy")

  // SaaS billing: pagos de tenants registrados por este SUPER_ADMIN.
  recordedTenantPayments TenantPayment[] @relation("TenantPaymentRecorder")

  // Cierres de Inventario
  closedDailyInventories DailyInventory[]

  // Recetas creadas
  createdRecipes Recipe[]

  // PrÃ©stamos creados
  createdLoans InventoryLoan[] @relation("LoanCreator")

  // Auditorías
  createdAudits  InventoryAudit[] @relation("AuditCreator")
  resolvedAudits InventoryAudit[] @relation("AuditResolver")

  // Órdenes de Compra
  createdPurchaseOrders  PurchaseOrder[] @relation("PurchaseOrderCreator")
  receivedPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderReceiver")

  // Procesamiento de Proteínas
  createdProteinProcessings   ProteinProcessing[] @relation("ProteinProcessingCreator")
  completedProteinProcessings ProteinProcessing[] @relation("ProteinProcessingCompleter")

  // Módulo Juegos
  reservationsCreated GameSession[] @relation("GameSessionStarter")
  gameSessionsEnded   GameSession[] @relation("GameSessionEnder")
  createdReservations Reservation[] @relation("ReservationCreator")

  // Módulo Financiero
  createdExpenses        Expense[]        @relation("ExpenseCreator")
  openedCashRegisters    CashRegister[]   @relation("CashRegisterOpener")
  closedCashRegisters    CashRegister[]   @relation("CashRegisterCloser")
  createdAccountsPayable AccountPayable[] @relation("AccountPayableCreator")
  createdAccountPayments AccountPayment[] @relation("AccountPaymentCreator")

  // Fase 2 — propuestas 001/002 (audit trail)
  cancelledDeductionRetries InventoryDeductionRetry[]  @relation("DeductionRetryCancelledBy")
  registeredSupplierPrices  SupplierItemPriceHistory[] @relation("SupplierPriceRegisteredBy")

  // Conteos físicos semanales (§51.A)
  createdWeeklyCounts WeeklyCount[]

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, email])
  @@index([email])
  @@index([role])
  @@index([tenantId])
}

// ============================================================================
// Ã�REAS DE TRABAJO
// ============================================================================

model Area {
  id          String   @id @default(cuid())
  name        String
  description String?
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Relaciones
  inventoryLocations InventoryLocation[]
  inventoryMovements InventoryMovement[]

  // Requisiciones
  requisitionsTarget Requisition[] @relation("RequisitionTarget")
  requisitionsSource Requisition[] @relation("RequisitionSource")

  // POS - Ventas
  salesOrders SalesOrder[]

  // Inventarios Diarios
  dailyInventories DailyInventory[]

  // Auditorías
  audits InventoryAudit[]

  // Procesamiento de Proteínas
  proteinProcessings ProteinProcessing[]

  // Items críticos por área
  criticalItems AreaCriticalItem[]

  // Conteos semanales (§51.A)
  weeklyCountsAsPrincipal  WeeklyCount[] @relation("WeeklyCountPrincipal")
  weeklyCountsAsProduction WeeklyCount[] @relation("WeeklyCountProduction")

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([branchId])
  @@index([tenantId])
}

// ============================================================================
// INVENTARIO
// ============================================================================

model InventoryItem {
  id             String   @id @default(cuid())
  sku            String
  name           String
  description    String?
  type           String // RAW_MATERIAL, SUB_RECIPE, FINISHED_GOOD
  category       String?
  baseUnit       String // KG, L, UNIT, G, ML, PORTION
  purchaseUnit   String?
  conversionRate Float?
  minimumStock   Float    @default(0)
  reorderPoint   Float    @default(0)
  isActive       Boolean  @default(true)
  isCritical     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Relaciones
  stockLevels       InventoryLocation[]
  movements         InventoryMovement[]
  costHistory       CostHistory[]
  recipeIngredients RecipeIngredient[]
  outputRecipes     Recipe[]            @relation("RecipeOutput")

  requisitionItems RequisitionItem[]

  // Préstamos
  loans InventoryLoan[]

  // Inventario Diario
  dailyCounts DailyInventoryItem[]

  // Auditorías
  auditItems InventoryAuditItem[]

  // Órdenes de Compra
  supplierItems      SupplierItem[]
  purchaseOrderItems PurchaseOrderItem[]

  // Procesamiento de Proteínas
  proteinSources ProteinProcessing[] @relation("ProteinSource")
  proteinOutputs ProteinSubProduct[] @relation("ProteinOutput")

  // Plantillas de Procesamiento
  templateSources ProcessingTemplate[]       @relation("TemplateSource")
  templateOutputs ProcessingTemplateOutput[] @relation("TemplateOutput")

  // Items críticos por área
  areaCriticalItems AreaCriticalItem[]

  // ── Beverage fields (Table-Pong / bar) ──────────────────────────────────
  isBeverage          Boolean @default(false)
  beverageCategory    String? // BEER, WINE, SPIRIT, COCKTAIL, SOFT_DRINK, WATER, JUICE, HOT
  beverageSubCategory String? // IPA, LAGER, ROSÉ, etc.
  isAlcoholic         Boolean @default(false)
  servingSize         Float? // Standard serving in baseUnit
  servingSizeUnit     String? // CL, ML, OZ

  // Familia de producto (SKU Studio)
  productFamilyId String?
  productFamily   ProductFamily? @relation(fields: [productFamilyId], references: [id])

  // Conteos Físicos (InventoryCycle)
  cycleSnapshots InventoryCycleSnapshot[]

  // Histórico de precios por proveedor (Fase 2 — propuesta 002)
  supplierPriceHistory SupplierItemPriceHistory[]

  // Conteos físicos semanales — items contados (§51.A)
  weeklyCountItems WeeklyCountItem[]

  // Multi-tenant (Fase 1.D-α). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, sku])
  @@index([sku])
  @@index([type])
  @@index([category])
  @@index([name])
  @@index([isBeverage])
  @@index([productFamilyId])
  @@index([tenantId])
}

// ============================================================================
// ITEMS CRÍTICOS POR ÁREA (Lista independiente por ubicación)
// ============================================================================

model AreaCriticalItem {
  id              String        @id @default(cuid())
  areaId          String
  area            Area          @relation(fields: [areaId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([areaId, inventoryItemId])
  @@index([areaId])
}

model InventoryLocation {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  areaId          String
  area            Area          @relation(fields: [areaId], references: [id])
  currentStock    Float         @default(0)
  lastCountDate   DateTime?

  @@unique([inventoryItemId, areaId])
  @@index([inventoryItemId])
  @@index([areaId])
}

// ============================================================================
// MOVIMIENTOS DE INVENTARIO
// ============================================================================

model InventoryMovement {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  movementType String // PURCHASE, SALE, PRODUCTION_IN, PRODUCTION_OUT, ADJUSTMENT_IN, ADJUSTMENT_OUT, TRANSFER, WASTE
  quantity     Float
  unit         String

  // Costo
  unitCost  Float?
  totalCost Float?

  // Documento de soporte
  referenceNumber String?
  documentUrl     String?
  documentType    String?

  // Notas
  reason String?
  notes  String?

  // AuditorÃ­a
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  // VinculaciÃ³n con venta (si aplica)
  salesOrderId String?
  salesOrder   SalesOrder? @relation("SaleMovements", fields: [salesOrderId], references: [id])

  // VinculaciÃ³n con prÃ©stamo
  loanId String?
  loan   InventoryLoan? @relation(fields: [loanId], references: [id])

  // Ubicación del movimiento
  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id])

  // Vinculaciones cruzadas (trazabilidad completa)
  productionOrderId   String?
  requisitionId       String?
  purchaseOrderId     String?
  auditId             String?
  proteinProcessingId String?

  @@index([inventoryItemId])
  @@index([movementType])
  @@index([createdAt])
  @@index([salesOrderId])
  @@index([loanId])
  @@index([createdById])
  @@index([areaId])
  @@index([productionOrderId])
  @@index([requisitionId])
  @@index([purchaseOrderId])
}

// ============================================================================
// CONTEO FÍSICO SEMANAL (§51.A)
// ============================================================================
// Persiste cada conteo aplicado en /conteo-semanal como entidad para:
//   - Historial de conteos (cuántos conté esta semana vs la anterior)
//   - Comparativa semana N vs N-1 (variación por SKU, por categoría)
//   - Reporte de pérdidas/mermas no registradas en diario
// El movimiento real de stock sigue siendo InventoryMovement(ADJUSTMENT_*);
// WeeklyCount es snapshot inmutable + denormalizado de qué se contó.

model WeeklyCount {
  id String @id @default(cuid())

  // Correlativo legible por tenant. Ej: "INV-2026-W23-001"
  countNumber String

  countDate DateTime @default(now())

  // Almacén principal contado (always required).
  principalAreaId String
  principalArea   Area   @relation("WeeklyCountPrincipal", fields: [principalAreaId], references: [id])

  // Si fue modo dual, área producción contada también.
  productionAreaId String?
  productionArea   Area?   @relation("WeeklyCountProduction", fields: [productionAreaId], references: [id])

  // DRAFT (preview cargado pero no aplicado) | APPLIED (ajustes generados).
  // En el flujo actual de applyPhysicalCountAction se persiste directo en APPLIED.
  status String @default("APPLIED")

  notes String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  appliedAt DateTime?

  items WeeklyCountItem[]

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, countNumber])
  @@index([tenantId])
  @@index([countDate])
  @@index([principalAreaId])
}

model WeeklyCountItem {
  id            String      @id @default(cuid())
  weeklyCountId String
  weeklyCount   WeeklyCount @relation(fields: [weeklyCountId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  // Snapshot denormalizado en el momento del conteo (resistente a cambios
  // posteriores de nombre/categoría del catálogo).
  sku      String
  name     String
  category String?
  baseUnit String

  // Almacén principal.
  stockBeforePrincipal Float
  qtyCountedPrincipal  Float
  variancePrincipal    Float   // qtyCounted - stockBefore (puede ser negativa)

  // Almacén producción (solo si modo dual).
  stockBeforeProduction Float?
  qtyCountedProduction  Float?
  varianceProduction    Float?

  // FK NO tenant-aware (scope vía weeklyCount.tenantId).

  @@unique([weeklyCountId, inventoryItemId])
  @@index([weeklyCountId])
  @@index([inventoryItemId])
}

// ============================================================================
// HISTORIAL DE COSTOS
// ============================================================================

model CostHistory {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  costPerUnit   Float
  currency      String  @default("USD")
  isCalculated  Boolean @default(false)
  costBreakdown String? // JSON string

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  reason      String?
  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])

  @@index([inventoryItemId])
  @@index([effectiveFrom])
}

// ============================================================================
// RECETAS
// ============================================================================

model Recipe {
  id          String  @id @default(cuid())
  name        String
  description String?

  outputItemId   String
  outputItem     InventoryItem @relation("RecipeOutput", fields: [outputItemId], references: [id])
  outputQuantity Float         @default(1)
  outputUnit     String

  yieldPercentage Float @default(100)
  prepTime        Int?
  cookTime        Int?

  isApproved Boolean @default(false)
  isActive   Boolean @default(true)
  version    Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  // Multi-tenant (Fase 1.B). Opcional por ahora; backfill en 1.C, NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Relaciones
  ingredients      RecipeIngredient[]
  productionOrders ProductionOrder[]

  @@index([outputItemId])
  @@index([tenantId])
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  ingredientItemId String
  ingredientItem   InventoryItem @relation(fields: [ingredientItemId], references: [id])

  quantity        Float
  unit            String
  wastePercentage Float   @default(0)
  notes           String?
  sortOrder       Int     @default(0)

  @@unique([recipeId, ingredientItemId])
  @@index([recipeId])
}

// ============================================================================
// Ã“RDENES DE PRODUCCIÃ“N
// ============================================================================

model ProductionOrder {
  id          String @id @default(cuid())
  orderNumber String

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  outputItemId    String
  plannedQuantity Float
  actualQuantity  Float?
  unit            String

  status   String @default("DRAFT") // DRAFT, APPROVED, IN_PROGRESS, COMPLETED, CANCELLED
  priority Int    @default(0)

  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?

  actualYieldPercentage Float?
  actualCost            Float?

  notes String?

  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, orderNumber])
  @@index([status])
  @@index([scheduledDate])
  @@index([tenantId])
}

// ============================================================================
// PROCESAMIENTO Y DESPOSTE DE PROTEÍNAS
// ============================================================================

model ProteinProcessing {
  id   String @id @default(cuid())
  code String // Ej: PROT-2026-001 — unique compuesto con tenantId abajo

  // Fecha del procesamiento
  processDate DateTime @default(now())

  // Producto a procesar (item del inventario - ej: Res entera, Pollo entero)
  sourceItemId String
  sourceItem   InventoryItem @relation("ProteinSource", fields: [sourceItemId], references: [id])

  // Proveedor (opcional)
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  supplierName String? // Por si no está en el sistema

  // Pesos
  frozenWeight  Float // Peso congelado inicial (kg)
  drainedWeight Float // Peso escurrido/descongelado (kg)

  // Totales calculados
  totalSubProducts Float  @default(0) // Suma de pesos de subproductos
  wasteWeight      Float  @default(0) // Desperdicio (kg) calculado (Drained - SubProducts)
  reportedWaste    Float? // Desperdicio reportado manualmente (kg)
  wastePercentage  Float  @default(0) // % de desperdicio
  yieldPercentage  Float  @default(0) // % de rendimiento

  // Estado
  status String @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED, CANCELLED

  // Paso del procesamiento en cadena
  processingStep String @default("LIMPIEZA") // LIMPIEZA, MASERADO, DISTRIBUCION, CUSTOM

  // Encadenamiento: referencia al procesamiento padre (si es un paso posterior)
  parentProcessingId String?
  parentProcessing   ProteinProcessing?  @relation("ProcessingChain", fields: [parentProcessingId], references: [id])
  childProcessings   ProteinProcessing[] @relation("ProcessingChain")

  // Área donde se realiza el procesamiento
  areaId String
  area   Area   @relation(fields: [areaId], references: [id])

  notes String?

  // Auditoría
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String
  createdBy     User      @relation("ProteinProcessingCreator", fields: [createdById], references: [id])
  completedAt   DateTime?
  completedById String?
  completedBy   User?     @relation("ProteinProcessingCompleter", fields: [completedById], references: [id])

  // Subproductos resultantes
  subProducts ProteinSubProduct[]

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, code])
  @@index([processDate])
  @@index([status])
  @@index([sourceItemId])
  @@index([parentProcessingId])
  @@index([tenantId])
}

model ProteinSubProduct {
  id String @id @default(cuid())

  processingId String
  processing   ProteinProcessing @relation(fields: [processingId], references: [id], onDelete: Cascade)

  // Item de inventario resultante (ej: Lomo, Costilla, Pechuga)
  outputItemId String?
  outputItem   InventoryItem? @relation("ProteinOutput", fields: [outputItemId], references: [id])

  // Nombre del subproducto (por si no está en inventario)
  name String

  // Peso y unidades obtenidas
  weight   Float // Peso en kg
  units    Int    @default(1) // Cantidad de piezas
  unitType String @default("KG") // KG, UNIDAD, PIEZA

  // Costo calculado (proporcional al peso)  
  estimatedCost Float @default(0)

  notes     String?
  sortOrder Int     @default(0)

  @@index([processingId])
  @@index([outputItemId])
}

// ============================================================================
// PLANTILLAS DE PROCESAMIENTO DE PROTEÍNAS
// ============================================================================

model ProcessingTemplate {
  id          String  @id @default(cuid())
  name        String // Ej: "Procesamiento de Lomito", "Procesamiento de Pollo"
  description String?

  // Item fuente (materia prima)
  sourceItemId String
  sourceItem   InventoryItem @relation("TemplateSource", fields: [sourceItemId], references: [id])

  // Paso de procesamiento que esta plantilla cubre (puede haber varias plantillas por item fuente, una por paso)
  processingStep String @default("LIMPIEZA") // LIMPIEZA, MASERADO, DISTRIBUCION, CUSTOM

  // Si el peso de salida puede ser mayor al de entrada (ej: maserado agrega condimentos)
  canGainWeight Boolean @default(false)

  // Orden en la cadena de pasos para este item fuente
  chainOrder Int @default(0) // 0=primer paso, 1=segundo, etc.

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Sub-productos permitidos en este paso
  allowedOutputs ProcessingTemplateOutput[]

  @@index([sourceItemId])
  @@index([processingStep])
}

model ProcessingTemplateOutput {
  id         String             @id @default(cuid())
  templateId String
  template   ProcessingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Item de salida permitido
  outputItemId String
  outputItem   InventoryItem @relation("TemplateOutput", fields: [outputItemId], references: [id])

  // Peso esperado (referencia para el usuario)
  expectedWeight Float? // Peso promedio esperado en KG
  expectedUnits  Int? // Unidades esperadas
  sortOrder      Int    @default(0)

  // Indica si este output es un producto intermedio (input del siguiente paso) o un producto final
  isIntermediate Boolean @default(false) // true = se usa como input del siguiente paso

  @@unique([templateId, outputItemId])
  @@index([templateId])
}

