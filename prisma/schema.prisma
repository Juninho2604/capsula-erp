  @@index([tenantId])
}

model InventoryAuditItem {
  id      String         @id @default(cuid())
  auditId String
  audit   InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  // Valores
  systemStock  Float // Stock que decía el sistema al momento de crear la auditoría
  countedStock Float // Stock real contado
  difference   Float // Calculado: counted - system

  costSnapshot Float? // Costo unitario en ese momento

  notes String?

  @@index([auditId])
  @@index([inventoryItemId])
}

// ============================================================================
// PROVEEDORES Y ÓRDENES DE COMPRA
// ============================================================================

model Supplier {
  id          String  @id @default(cuid())
  name        String
  code        String? // Código interno del proveedor — unique compuesto con tenantId abajo
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.B). Opcional por ahora; backfill en 1.C, NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Relaciones
  purchaseOrders     PurchaseOrder[]
  // Productos que suministra este proveedor
  suppliedItems      SupplierItem[]
  // Procesamiento de Proteínas
  proteinProcessings ProteinProcessing[]
  // Módulo Financiero
  accountsPayable    AccountPayable[]
  // Histórico de precios (Fase 2 — propuesta 002)
  priceHistory       SupplierItemPriceHistory[]

  @@unique([tenantId, code])
  @@index([name])
  @@index([tenantId])
}

// Relación entre Proveedor y los Items que puede suministrar
model SupplierItem {
  id              String        @id @default(cuid())
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  // Precio de referencia del proveedor
  unitPrice    Float?
  leadTimeDays Int? // Tiempo de entrega en días
  minimumOrder Float? // Cantidad mínima de pedido

  isPreferred Boolean @default(false) // Proveedor preferido para este item

  @@unique([supplierId, inventoryItemId])
  @@index([supplierId])
  @@index([inventoryItemId])
}

model PurchaseOrder {
  id          String  @id @default(cuid())
  orderNumber String // Ej: OC-2026-0001 — unique compuesto con tenantId abajo
  orderName   String? // Nombre descriptivo: VEGETALES, COCHE, etc.

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  status String @default("DRAFT") // DRAFT, SENT, PARTIAL, RECEIVED, CANCELLED

  // Fechas
  orderDate    DateTime  @default(now())
  expectedDate DateTime? // Fecha esperada de recepción
  receivedDate DateTime?

  // Totales
  subtotal    Float @default(0)
  taxAmount   Float @default(0)
  totalAmount Float @default(0)

  notes         String?
  internalNotes String? // Notas internas no visibles en la orden impresa

  // Auditoría
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("PurchaseOrderCreator", fields: [createdById], references: [id])

  receivedById String?
  receivedBy   User?   @relation("PurchaseOrderReceiver", fields: [receivedById], references: [id])

  // Items de la orden
  items                 PurchaseOrderItem[]
  accountsPayable       AccountPayable[]
  // Fase 2 — propuesta 002: cambios de precio que dispararon esta OC
  triggeredPriceChanges SupplierItemPriceHistory[]

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, orderNumber])
  @@index([status])
  @@index([orderDate])
  @@index([supplierId])
  @@index([tenantId])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  // Cantidades
  quantityOrdered  Float // Cantidad solicitada
  quantityReceived Float  @default(0) // Cantidad recibida
  unit             String

  // Precios
  unitPrice  Float @default(0)
  totalPrice Float @default(0)

  // Información adicional
  notes String?

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

// ============================================================================
// AUDIT LOG - REGISTRO FORENSE DE OPERACIONES
// ============================================================================
// Esta tabla NUNCA se borra. Solo se puede archivar a cold storage.
// Toda server action que modifique datos debe crear un AuditLog.
// ============================================================================

model AuditLog {
  id String @id @default(cuid())

  // QUIÉN
  userId   String
  userName String // Snapshot para no depender de JOIN
  userRole String // Rol al momento de la acción

  // QUÉ
  action     String // CREATE, UPDATE, DELETE, VOID, APPROVE, REJECT, LOGIN, LOGOUT
  entityType String // SalesOrder, InventoryMovement, Recipe, etc.
  entityId   String // ID del registro afectado

  // DETALLE
  description String? // Descripción legible: "Creó orden REST-2026-03-15-001"
  changes     String? // JSON: { field: { from: "X", to: "Y" } }
  metadata    String? // JSON: datos contextuales adicionales

  // DESDE DÓNDE
  ipAddress String?
  userAgent String?
  deviceId  String? // Identificador de terminal/caja

  // CUÁNDO
  createdAt DateTime @default(now())

  // CONTEXTO OPERATIVO
  module String? // POS, INVENTORY, PRODUCTION, RECIPE, etc.

  // Multi-tenant (Fase 1.D-α). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([module])
  @@index([tenantId])
}

// ============================================================================
// MÓDULO FINANCIERO - GASTOS, CAJA Y CUENTAS POR PAGAR
// ============================================================================

/// Categorías de gastos operativos (alquiler, servicios, nómina, etc.)
model ExpenseCategory {
  id          String  @id @default(cuid())
  name        String // ej: "Alquiler", "Servicios Públicos", "Nómina" — unique compuesto con tenantId abajo
  description String?
  color       String? // hex color para UI, ej: "#3B82F6"
  icon        String? // emoji, ej: "🏠"
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant (Fase 1.B). Opcional por ahora; backfill en 1.C, NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  expenses Expense[]

  @@unique([tenantId, name])
  @@index([isActive])
  @@index([tenantId])
}

/// Registro de gastos operativos (no de compras de inventario)
model Expense {
  id String @id @default(cuid())

  // Descripción
  description String // Ej: "Pago alquiler local enero 2026"
  notes       String? // Notas adicionales o referencia

  // Clasificación
  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])

  // Monto
  amountUsd    Float // Monto en USD (moneda base del sistema)
  amountBs     Float? // Monto en Bs (opcional, para referencia)
  exchangeRate Float? // Tasa usada para conversión

  // Pago
  paymentMethod String // CASH_USD, CASH_BS, ZELLE, BANK_TRANSFER, MOBILE_PAY, CHECK, OTHER
  paymentRef    String? // Referencia de pago (número de transacción, cheque, etc.)
  paidAt        DateTime // Fecha del pago/gasto

  // Estado
  status     String    @default("CONFIRMED") // CONFIRMED, VOID
  voidReason String?
  voidedAt   DateTime?
  voidedById String?

  // Comprobante
  receiptUrl String? // URL de imagen/PDF del comprobante (opcional)

  // Período al que pertenece
  periodMonth Int // 1-12
  periodYear  Int

  // Auditoría
  createdById String
  createdBy   User     @relation("ExpenseCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([categoryId])
  @@index([paidAt])
  @@index([periodYear, periodMonth])
  @@index([status])
  @@index([createdById])
  @@index([tenantId])
}

/// Apertura y cierre de caja (para cuadre de efectivo al inicio/fin del turno)
model CashRegister {
  id String @id @default(cuid())

  // Identificador de caja/terminal
  registerName String // ej: "Caja Restaurante", "Caja Delivery"
  shiftDate    DateTime // Fecha del turno (solo fecha, sin hora)
  shiftType    String   @default("DAY") // DAY, NIGHT, MORNING

  // Estado
  status String @default("OPEN") // OPEN, CLOSED

  // Apertura
  openingCashUsd Float    @default(0) // Fondo inicial en USD
  openingCashBs  Float    @default(0) // Fondo inicial en Bs
  openedAt       DateTime @default(now())
  openedById     String
  openedBy       User     @relation("CashRegisterOpener", fields: [openedById], references: [id])

  // Cierre
  closingCashUsd Float? // Efectivo contado al cierre en USD
  closingCashBs  Float? // Efectivo contado al cierre en Bs
  closedAt       DateTime?
  closedById     String?
  closedBy       User?     @relation("CashRegisterCloser", fields: [closedById], references: [id])

  // Resumen calculado al cierre
  totalSalesUsd Float? // Total ventas del turno
  totalExpenses Float? // Total gastos del turno
  expectedCash  Float? // Efectivo esperado (apertura + ventas efectivo - gastos)
  difference    Float? // Diferencia (cierre contado - esperado)

  // Desglose de billetes (JSON nullable — no rompe registros existentes)
  // Formato: {"100":6,"50":2,"20":29,"10":10,"5":6,"1":21,"total":1431.00}
  openingDenominationsJson String?
  closingDenominationsJson String?

  // Operadoras activas en este turno (JSON array de nombres, nullable)
  // Ejemplo: ["Ana García", "María López"]
  operatorsJson String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([shiftDate])
  @@index([status])
  @@index([openedById])
  @@index([tenantId])
}

/// Cuentas por pagar — facturas/deudas pendientes con proveedores u otros acreedores
model AccountPayable {
  id String @id @default(cuid())

  // Descripción
  description   String // Ej: "Factura vegetales 15/03/2026"
  invoiceNumber String? // Número de factura del proveedor
  invoiceUrl    String? // URL del comprobante

  // Acreedor
  supplierId   String? // Si es un proveedor del sistema
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  creditorName String? // Si no está en el sistema de proveedores

  // Montos
  totalAmountUsd Float // Monto total de la deuda en USD
  paidAmountUsd  Float @default(0) // Monto pagado acumulado
  remainingUsd   Float // Monto pendiente (calculado: total - paid)

  // Fechas
  invoiceDate DateTime // Fecha de la factura
  dueDate     DateTime? // Fecha de vencimiento (opcional)
  fullyPaidAt DateTime? // Fecha en que quedó saldada

  // Estado
  status String @default("PENDING") // PENDING, PARTIAL, PAID, OVERDUE, DISPUTED, VOID

  // Relación con PurchaseOrder (si aplica)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  // Auditoría
  createdById String
  createdBy   User     @relation("AccountPayableCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments AccountPayment[]

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([status])
  @@index([dueDate])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([createdById])
  @@index([tenantId])
}

/// Pagos individuales aplicados a una cuenta por pagar
model AccountPayment {
  id               String         @id @default(cuid())
  accountPayableId String
  accountPayable   AccountPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)

  amountUsd     Float
  amountBs      Float?
  exchangeRate  Float?
  paymentMethod String // CASH_USD, CASH_BS, ZELLE, BANK_TRANSFER, MOBILE_PAY, CHECK
  paymentRef    String? // Referencia de transferencia, cheque, etc.
  paidAt        DateTime

  notes String?

  createdById String
  createdBy   User     @relation("AccountPaymentCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  // Multi-tenant (Fase 1.D-β). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([accountPayableId])
  @@index([paidAt])
  @@index([tenantId])
}

// ============================================================================
// MODELO OPERATIVO RESTAURANTE
// ============================================================================

model Branch {
  id           String   @id @default(cuid())
  code         String
  name         String
  legalName    String?
  timezone     String   @default("America/Caracas")
  currencyCode String   @default("USD")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  areas           Area[]
  serviceZones    ServiceZone[]
  tableOrStations TableOrStation[]
  openTabs        OpenTab[]
  salesOrders     SalesOrder[]
  gameStations    GameStation[]
  waiters         Waiter[]

  // Módulo Gestión de Deliverys (módulo aislado, feature flag deliveryOps).
  deliveryConfig  BranchDeliveryConfig?
  deliveryZones   DeliveryZone[]
  deliveryOrders  DeliveryOrder[]

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Waiter {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  pin       String?
  isActive  Boolean  @default(true)
  isCaptain Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  openTabs            OpenTab[]
  salesOrders         SalesOrder[]
  voidedItems         SalesOrderItem[] @relation("ItemVoidedByWaiter")
  transfersFrom       TableTransfer[]  @relation("TransferFrom")
  transfersTo         TableTransfer[]  @relation("TransferTo")
  transfersAuthorized TableTransfer[]  @relation("TransferAuthorizedByWaiter")

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([branchId, isActive])
  @@index([tenantId])
}

model TableTransfer {
  id                   String          @id @default(cuid())
  openTabId            String
  openTab              OpenTab         @relation(fields: [openTabId], references: [id], onDelete: Cascade)
  fromWaiterId         String
  fromWaiter           Waiter          @relation("TransferFrom", fields: [fromWaiterId], references: [id])
  toWaiterId           String
  toWaiter             Waiter          @relation("TransferTo", fields: [toWaiterId], references: [id])
  fromTableId          String?
  fromTable            TableOrStation? @relation("TransferFromTable", fields: [fromTableId], references: [id])
  toTableId            String?
  toTable              TableOrStation? @relation("TransferToTable", fields: [toTableId], references: [id])
  authorizedByWaiterId String?
  authorizedByWaiter   Waiter?         @relation("TransferAuthorizedByWaiter", fields: [authorizedByWaiterId], references: [id])
  authorizedByUserId   String?
  authorizedByUser     User?           @relation("TransferAuthorizedByUser", fields: [authorizedByUserId], references: [id])
  authorizedNote       String?
  reason               String?
  transferredAt        DateTime        @default(now())

  @@index([openTabId])
  @@index([fromWaiterId])
  @@index([toWaiterId])
  @@index([fromTableId])
  @@index([toTableId])
  @@index([authorizedByUserId])
}

model ServiceZone {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  code      String?
  name      String
  zoneType  String   @default("DINING") // DINING, BAR, TERRACE, VIP
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tablesOrStations TableOrStation[]
  openTabs         OpenTab[]
  salesOrders      SalesOrder[]

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([branchId, name])
  @@index([branchId, zoneType])
  @@index([tenantId])
}

model TableOrStation {
  id            String      @id @default(cuid())
  branchId      String
  branch        Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceZoneId String
  serviceZone   ServiceZone @relation(fields: [serviceZoneId], references: [id], onDelete: Cascade)
  code          String
  name          String
  stationType   String      @default("TABLE") // TABLE, BAR_SEAT, VIP_ROOM
  capacity      Int         @default(1)
  currentStatus String      @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED, OUT_OF_SERVICE
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  openTabs      OpenTab[]
  salesOrders   SalesOrder[]
  transfersFrom TableTransfer[] @relation("TransferFromTable")
  transfersTo   TableTransfer[] @relation("TransferToTable")

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([branchId, code])
  @@index([serviceZoneId, stationType])
  @@index([currentStatus])
  @@index([tenantId])
}

model OpenTab {
  id                 String          @id @default(cuid())
  branchId           String
  branch             Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceZoneId      String?
  serviceZone        ServiceZone?    @relation(fields: [serviceZoneId], references: [id])
  tableOrStationId   String?
  tableOrStation     TableOrStation? @relation(fields: [tableOrStationId], references: [id])
  tabCode            String // unique compuesto con tenantId abajo
  customerLabel      String?
  customerPhone      String?
  guestCount         Int             @default(1)
  status             String          @default("OPEN") // OPEN, PARTIALLY_PAID, CLOSED, CANCELLED
  serviceType        String          @default("TABLE_SERVICE") // TABLE_SERVICE, BAR_TAB, EVENT
  runningSubtotal    Float           @default(0)
  runningDiscount    Float           @default(0)
  runningTax         Float           @default(0)
  runningTotal       Float           @default(0)
  balanceDue         Float           @default(0)
  totalServiceCharge Float           @default(0) // Service charge acumulado de la mesa
  totalTip           Float           @default(0) // Propina voluntaria acumulada
  tipPercent         Float? // Propina seleccionada por el cliente (0, 10, 15, 20)
  tipAmount          Float? // tipPercent/100 × runningTotal (neto post-descuento) — ver §46
  version            Int             @default(0)
  openedAt           DateTime        @default(now())
  closedAt           DateTime?
  updatedAt          DateTime        @updatedAt
  notes              String?
  waiterLabel        String?
  openedById         String
  openedBy           User            @relation("OpenTabOpener", fields: [openedById], references: [id])
  assignedWaiterId   String?
  assignedWaiter     User?           @relation("OpenTabAssignee", fields: [assignedWaiterId], references: [id])
  waiterProfileId    String?
  waiterProfile      Waiter?         @relation(fields: [waiterProfileId], references: [id])
  closedById         String?
  closedBy           User?           @relation("OpenTabCloser", fields: [closedById], references: [id])

  orders        SalesOrder[]
  orderLinks    OpenTabOrder[]
  paymentSplits PaymentSplit[]
  subAccounts   TabSubAccount[]
  transfers     TableTransfer[]

  // Soft Delete
  deletedAt   DateTime?
  deletedById String?

  // Multi-tenant (Fase 1.D-γ). Opcional por ahora; NOT NULL en 1.E.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, tabCode])
  @@index([branchId, status])
  @@index([tableOrStationId])
  @@index([tenantId])
}

model OpenTabOrder {
  id           String     @id @default(cuid())
  openTabId    String
  openTab      OpenTab    @relation(fields: [openTabId], references: [id], onDelete: Cascade)
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now())

  @@unique([openTabId, salesOrderId])
  @@index([salesOrderId])
}

model PaymentSplit {
  id                  String         @id @default(cuid())
  openTabId           String
  openTab             OpenTab        @relation(fields: [openTabId], references: [id], onDelete: Cascade)
  salesOrderId        String?
  salesOrder          SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  // null = pago de la mesa completa; set = pago de una subcuenta específica
  subAccountId        String?
  subAccount          TabSubAccount? @relation(fields: [subAccountId], references: [id])
  splitLabel          String
  splitType           String         @default("EQUAL") // EQUAL, ITEM_BASED, CUSTOM
  paymentMethod       String?
  status              String         @default("PENDING") // PENDING, PAID, VOID
  subtotal            Float          @default(0)
  discount            Float          @default(0)
  tax                 Float          @default(0)
  serviceChargeAmount Float          @default(0) // Cargo de servicio prorrateado en este split
  tipAmount           Float          @default(0) // Propina prorrateada en este split
  total               Float          @default(0)
  paidAmount          Float          @default(0)
  createdAt           DateTime       @default(now())
  paidAt              DateTime?
  notes               String?

  @@index([openTabId, status])
  @@index([salesOrderId])
  @@index([subAccountId])
}

// ─── SUBCUENTAS ──────────────────────────────────────────────────────────────
// Una subcuenta es una división lógica dentro de una mesa (OpenTab).
// Hasta 25 subcuentas por mesa. Cada una tiene su propio subtotal y service charge.
// Los ítems se asignan a subcuentas via SubAccountItem (pueden ser parciales: qty < order item qty).

model TabSubAccount {
  id        String  @id @default(cuid())
  openTabId String
  openTab   OpenTab @relation(fields: [openTabId], references: [id], onDelete: Cascade)

  label     String // "Cuenta 1", "Carlos", etc. — editable
  sortOrder Int    @default(0)
  status    String @default("OPEN") // OPEN | PAID | VOID

  // Totales propios (recalculados por el server action en cada mutación)
  subtotal      Float @default(0)
  serviceCharge Float @default(0) // siempre subtotal * 0.10
  total         Float @default(0) // subtotal + serviceCharge

  // Cobro (se populan cuando status = PAID)
  paidAmount    Float     @default(0)
  paymentMethod String?
  paidAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         SubAccountItem[]
  paymentSplits PaymentSplit[]

  @@index([openTabId, status])
}

model SubAccountItem {
  id           String        @id @default(cuid())
  subAccountId String
  subAccount   TabSubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)

  salesOrderItemId String
  salesOrderItem   SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Cascade)

  // Cantidad asignada a esta subcuenta (puede ser menor que SalesOrderItem.quantity)
  quantity  Int
  // Snapshot del precio al momento de asignar (unitPrice * quantity + modificadores prorrateados)
  lineTotal Float

  createdAt DateTime @default(now())

  @@index([subAccountId])
  @@index([salesOrderItemId])
}

// Líneas de pago de una orden (pagos mixtos: efectivo + zelle + punto, etc.)
model SalesOrderPayment {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  method       String // CASH | ZELLE | CARD | MOBILE_PAY | TRANSFER | CORTESIA
  amountUSD    Float
  amountBS     Float? // Monto en Bs si el pago fue en Bs
  exchangeRate Float? // Tasa usada para esta línea
  reference    String? // Número de referencia (transferencia, confirmación Zelle, etc.)
  createdAt    DateTime   @default(now())

  @@index([salesOrderId])
}

