# ─── Print Agent config (copiar a .env y editar) ──────────────────────

# URL del ERP en Vercel. Sin trailing slash.
ERP_URL=https://shanklish-erp-main.vercel.app

# API key compartido con el ERP (PRINT_AGENT_API_KEY en Vercel).
# Generar con: openssl rand -hex 32
API_KEY=cambia-esto

# Tenant del restaurante. Para Shanklish:
TENANT_ID=tnt_shanklish_caracas

# Frecuencia del polling (1000 = 1 segundo).
POLL_INTERVAL_MS=1000

# Mapping de estaciones lógicas → IP de la impresora AON. JSON serializado.
# Para añadir más impresoras: poner más objetos en el array.
PRINTERS_JSON=[{"station":"kitchen-1","ip":"192.168.1.50","port":9100}]

# Estación por defecto cuando un PrintJob no especifica `station`.
# Si no se setea, usa la primera de PRINTERS_JSON.
DEFAULT_STATION=kitchen-1
