# ─── Print Agent config (copiar a .env y editar) ──────────────────────

# URL del ERP. Sin trailing slash.
# Producción VPS: https://kpsula.app
# Producción Vercel (deprecated): https://shanklish-erp-main.vercel.app
ERP_URL=https://kpsula.app

# API key compartido con el ERP (PRINT_AGENT_API_KEY en el .env del servidor).
# Generar con: openssl rand -hex 32
API_KEY=cambia-esto

# Tenant del restaurante. Para Shanklish:
TENANT_ID=tnt_shanklish_caracas

# Frecuencia del polling (1000 = 1 segundo).
POLL_INTERVAL_MS=1000

# ─── Mapping estaciones → impresoras AON ──────────────────────────────
#
# JSON array. Cada item es { station, ip, port }.
#
# IMPORTANTE — Modo "fanout" (espejo): varias entradas con el mismo
# `station` provocan que el agent imprima EL MISMO job en TODAS ellas
# en paralelo. Útil cuando una estación lógica (ej. cocina) tiene 2
# comanderas físicas que deben recibir todas las comandas.
#
# Setup actual de Shanklish Caracas:
#   - barra      → 192.168.1.140  (bebidas)
#   - cocina #1  → 192.168.1.141  (Pase)
#   - cocina #2  → 192.168.1.142  (Caliente Shawarma)
#
# Hoy las 2 cocinas están en modo espejo (ambas imprimen todo lo que
# no es bebida) porque falta instalar la 4ta impresora (línea fría).
# Cuando llegue, separamos `kitchen-pase`, `kitchen-caliente`,
# `kitchen-frio` y reasignamos kitchenRouting por item del menú.
PRINTERS_JSON=[{"station":"bar","ip":"192.168.1.140","port":9100},{"station":"kitchen","ip":"192.168.1.141","port":9100},{"station":"kitchen","ip":"192.168.1.142","port":9100}]

# Estación por defecto cuando un PrintJob no especifica `station`.
DEFAULT_STATION=kitchen
